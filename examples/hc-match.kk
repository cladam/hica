module hc-match

fun hc_describe(x : int) : string
  match x
    0 -> "zero"
    1 -> "one"
    _ -> "many"

fun hc_respond(msg : string) : string
  match msg
    "hello" -> "hi there!"
    "bye" -> "see you!"
    _ -> "huh?"

fun main()
  println(hc_describe(1))
  println(hc_respond("hello"))
