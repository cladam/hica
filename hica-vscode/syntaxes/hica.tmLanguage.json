{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Hica",
  "scopeName": "source.hica",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#constants" },
    { "include": "#types" },
    { "include": "#constructors" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.hica",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hica",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.hica",
              "match": "\\\\[nrtf0\\\\\"'{}]"
            },
            {
              "name": "meta.interpolation.hica",
              "begin": "\\{",
              "end": "\\}",
              "beginCaptures": {
                "0": { "name": "punctuation.section.interpolation.begin.hica" }
              },
              "endCaptures": {
                "0": { "name": "punctuation.section.interpolation.end.hica" }
              },
              "patterns": [
                { "include": "source.hica" }
              ]
            }
          ]
        }
      ]
    },
    "chars": {
      "patterns": [
        {
          "name": "string.quoted.single.hica",
          "match": "'[^']'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.binary.hica",
          "match": "\\b0[bB][01_?]+\\b"
        },
        {
          "name": "constant.numeric.hex.hica",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.float.hica",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.hica",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.hica",
          "match": "\\b(if|else|match|for|in|while|loop|repeat|break|continue)\\b"
        },
        {
          "name": "keyword.declaration.hica",
          "match": "\\b(fun|let|var|struct|type|extern)\\b"
        },
        {
          "name": "keyword.import.hica",
          "match": "\\b(import|from|pub)\\b"
        },
        {
          "name": "keyword.test.hica",
          "match": "\\b(test)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.hica",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.option.hica",
          "match": "\\b(None)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.hica",
          "match": "\\b(int|float|bool|string|char|list|maybe|result)\\b"
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "name": "entity.name.tag.constructor.hica",
          "match": "\\b(Some|Ok|Err)\\b"
        },
        {
          "comment": "User-defined PascalCase constructors and type names",
          "name": "entity.name.type.hica",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "comment": "Function declaration name",
          "match": "\\b(fun)\\s+([a-z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.hica" },
            "2": { "name": "entity.name.function.hica" }
          }
        },
        {
          "comment": "Test declaration name",
          "match": "\\b(test)\\s+\"([^\"]+)\"",
          "captures": {
            "1": { "name": "keyword.test.hica" },
            "2": { "name": "entity.name.function.test.hica" }
          }
        },
        {
          "comment": "Function call",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.hica" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.hica",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.arrow.hica",
          "match": "=>"
        },
        {
          "name": "keyword.operator.thin-arrow.hica",
          "match": "->"
        },
        {
          "name": "keyword.operator.spread.hica",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range-inclusive.hica",
          "match": "\\.\\.="
        },
        {
          "name": "keyword.operator.range.hica",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.try.hica",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.comparison.hica",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.logical.hica",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.arithmetic.hica",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.hica",
          "match": "[<>]"
        },
        {
          "name": "keyword.operator.assignment.hica",
          "match": "="
        },
        {
          "name": "keyword.operator.or-pattern.hica",
          "match": "\\|"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.hica",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.hica",
          "match": ";"
        },
        {
          "name": "punctuation.separator.colon.hica",
          "match": ":"
        },
        {
          "name": "punctuation.accessor.dot.hica",
          "match": "\\."
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.hica",
          "match": "\\b[a-z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
