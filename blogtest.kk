fun cliarg/show(p : cliarg) : string
  "CliArg(" ++ "arg_name: " ++ p.arg_name ++ ", " ++ "arg_help: " ++ p.arg_help ++ ", " ++ "arg_required: " ++ p.arg_required.show ++ ")"

struct clispec
