  else if (((((((!(hc_hml_is_digit(hc_peek(s, pos))) || !(hc_hml_is_digit(hc_peek(s, (pos + 1))))) || (hc_peek(s, (pos + 2)) != ":")) || !(hc_hml_is_digit(hc_peek(s, (pos + 3))))) || !(hc_hml_is_digit(hc_peek(s, (pos + 4))))) || (hc_peek(s, (pos + 5)) != ":")) || !(hc_hml_is_digit(hc_peek(s, (pos + 6))))) || !(hc_hml_is_digit(hc_peek(s, (pos + 7))))) then
    Left("invalid time format in datetime")
  else
    val time_str : string = (((((((hc_peek(s, pos) ++ hc_peek(s, (pos + 1))) ++ ":") ++ hc_peek(s, (pos + 3))) ++ hc_peek(s, (pos + 4))) ++ ":") ++ hc_peek(s, (pos + 6))) ++ hc_peek(s, (pos + 7)))
    hc_finish_datetime(s, (pos + 8), date_str, time_str)

// .hc:343
pub fun hc_try_parse_date(s : string, pos : int, year : string)
  if ((pos + 6) > s.count) then
    Left("incomplete date")
  else if ((((!(hc_hml_is_digit(hc_peek(s, (pos + 1)))) || !(hc_hml_is_digit(hc_peek(s, (pos + 2))))) || (hc_peek(s, (pos + 3)) != "-")) || !(hc_hml_is_digit(hc_peek(s, (pos + 4))))) || !(hc_hml_is_digit(hc_peek(s, (pos + 5))))) then
    Left("invalid date format")
  else
    val date_str : string = ((((((year ++ "-") ++ hc_peek(s, (pos + 1))) ++ hc_peek(s, (pos + 2))) ++ "-") ++ hc_peek(s, (pos + 4))) ++ hc_peek(s, (pos + 5)))
    if ((hc_peek(s, (pos + 6)) == "T") || (hc_peek(s, (pos + 6)) == "t")) then hc_try_parse_datetime_time(s, (pos + 7), date_str) else hc_validated_datetime(date_str, (pos + 6))

// .hc:364
pub fun hc_parse_number_or_duration(s : string, pos : int)
  val sign_pos : int = if ((hc_peek(s, pos) == "+") || (hc_peek(s, pos) == "-")) then (pos + 1) else pos
  val sign_str : string = if (hc_peek(s, pos) == "-") then "-" else ""
  if ((hc_peek(s, sign_pos) == "0") && (hc_peek(s, (sign_pos + 1)) == "x")) then
    hc_parse_hex_int(s, (sign_pos + 2), sign_str)
  else if ((hc_peek(s, sign_pos) == "0") && (hc_peek(s, (sign_pos + 1)) == "o")) then
    hc_parse_octal_int(s, (sign_pos + 2), sign_str)
  else if ((hc_peek(s, sign_pos) == "0") && (hc_peek(s, (sign_pos + 1)) == "b")) then
    hc_parse_binary_int(s, (sign_pos + 2), sign_str)
  else
    val (digits_str, p2) = hc_parse_int_digits(s, sign_pos, "")
    if (digits_str.count == 0) then
      Left(("expected number at position " ++ show(pos)))
    else if ((((sign_str == "") && (digits_str.count == 4)) && (hc_peek(s, p2) == "-")) && hc_hml_is_digit(hc_peek(s, (p2 + 1)))) then
      hc_try_parse_date(s, p2, digits_str)
    else if ((((sign_str == "") && (digits_str.count == 2)) && (hc_peek(s, p2) == ":")) && hc_hml_is_digit(hc_peek(s, (p2 + 1)))) then
      hc_try_parse_time(s, p2, digits_str)
    else
      if (sign_str == "") then
        match hc_is_duration_unit(s, p2)
          Just((unit, p3)) ->
            Right((HDuration(digits_str.parse-int.default(0), unit), p3))
          Nothing ->
            hc_parse_number_rest(s, p2, (sign_str ++ digits_str))
      else
        hc_parse_number_rest(s, p2, (sign_str ++ digits_str))

// .hc:398
pub fun hc_parse_number_rest(s : string, pos : int, int_part : string)
  if (hc_peek(s, pos) == ".") then
    val (frac, p2) = hc_parse_int_digits(s, (pos + 1), "")
    if (frac.count == 0) then
      Left("expected digits after decimal point")
    else
      val float_str : string = ((int_part ++ ".") ++ frac)
      if ((hc_peek(s, p2) == "e") || (hc_peek(s, p2) == "E")) then
        val (exp, p3) = hc_parse_exponent(s, (p2 + 1))
        Right((HFloat(((float_str ++ "e") ++ exp).parse-float64.default(0.0)), p3))
      else
        Right((HFloat(float_str.parse-float64.default(0.0)), p2))
  else if ((hc_peek(s, pos) == "e") || (hc_peek(s, pos) == "E")) then
    val (exp, p2) = hc_parse_exponent(s, (pos + 1))
    Right((HFloat(((int_part ++ "e") ++ exp).parse-float64.default(0.0)), p2))
  else
    Right((HInt(int_part.parse-int.default(0)), pos))

// .hc:420
pub fun hc_parse_exponent(s : string, pos : int)
  val start : int = if ((hc_peek(s, pos) == "+") || (hc_peek(s, pos) == "-")) then (pos + 1) else pos
  val hc_sign : string = if (hc_peek(s, pos) == "-") then "-" else ""
  val (digits_str, p2) = hc_parse_int_digits(s, start, "")
  ((hc_sign ++ digits_str), p2)

// .hc:426
pub fun hc_parse_array(s : string, pos : int, items : list<hml>, text_elems : list<string>)
  val p1 : int = hc_skip_noise(s, pos)
  if (hc_peek(s, p1) == "]") then
    Right((HArray(items), (p1 + 1)))
  else
    match hc_parse_value(s, p1, text_elems)
      Right((v, p2)) ->
        val p3 = hc_skip_noise(s, p2)
        if (hc_peek(s, p3) == ",") then
          hc_parse_array(s, (p3 + 1), (items ++ [v]), text_elems)
        else if (hc_peek(s, p3) == "]") then Right((HArray((items ++ [v])), (p3 + 1))) else Left(("expected ',' or ']' in array at position " ++ show(p3)))
      Left(e) ->
        Left(e)

// .hc:439
pub fun hc_starts_with_at(s : string, pos : int, target : string) : bool
  if ((pos + target.count) > s.count) then False else (s.list.drop(pos).take(((pos + target.count)) - (pos)).string == target)

// .hc:448
pub fun hc_parse_string_value(s : string, p : int)
  if hc_starts_with_at(s, p, "\"\"\"") then
    hc_parse_ml_basic_string(s, (p + 3), "")
  else
    match hc_parse_basic_string(s, (p + 1), "")
      Right((v, p2)) ->
        Right((HStr(v), p2))
      Left(e) ->
        Left(e)

// .hc:457
pub fun hc_parse_literal_value(s : string, p : int)
  if hc_starts_with_at(s, p, "\'\'\'") then
    hc_parse_ml_literal_string(s, (p + 3), "")
  else
    match hc_parse_literal_string(s, (p + 1), "")
      Right((v, p2)) ->
        Right((HStr(v), p2))
      Left(e) ->
        Left(e)

// .hc:469
pub fun hc_parse_value(s : string, pos : int, text_elems : list<string>)
  val p : int = hc_skip_ws(s, pos)
  if (hc_peek(s, p) == "\"") then
    hc_parse_string_value(s, p)
  else if (hc_peek(s, p) == "\'") then
    hc_parse_literal_value(s, p)
  else if (hc_starts_with_at(s, p, "true") && !(hc_is_bare_key_char(hc_peek(s, (p + 4))))) then
    Right((HBool(True), (p + 4)))
  else if (hc_starts_with_at(s, p, "false") && !(hc_is_bare_key_char(hc_peek(s, (p + 5))))) then
    Right((HBool(False), (p + 5)))
  else if (hc_starts_with_at(s, p, "null") && !(hc_is_bare_key_char(hc_peek(s, (p + 4))))) then
    Right((HNull, (p + 4)))
  else if (hc_starts_with_at(s, p, "inf") && !(hc_is_bare_key_char(hc_peek(s, (p + 3))))) then
    Right((HFloat((1.0 / 0.0)), (p + 3)))
  else if (hc_starts_with_at(s, p, "-inf") && !(hc_is_bare_key_char(hc_peek(s, (p + 4))))) then
    Right((HFloat((0.0 - (1.0 / 0.0))), (p + 4)))
  else if (hc_starts_with_at(s, p, "nan") && !(hc_is_bare_key_char(hc_peek(s, (p + 3))))) then
    Right((HFloat((0.0 / 0.0)), (p + 3)))
  else if (hc_peek(s, p) == "[") then
    hc_parse_array(s, (p + 1), [], text_elems)
  else if (hc_peek(s, p) == "@") then
    hc_parse_inline_element(s, p, text_elems)
  else if ((hc_hml_is_digit(hc_peek(s, p)) || (hc_peek(s, p) == "+")) || (hc_peek(s, p) == "-")) then
    hc_parse_number_or_duration(s, p)
  else
    Left(((("unexpected character '" ++ hc_peek(s, p)) ++ "' at position ") ++ show(p)))

// .hc:502
pub fun hc_parse_ml_basic_string(s : string, pos : int, acc : string)
  val start : int = if (hc_peek(s, pos) == "\n") then (pos + 1) else if ((hc_peek(s, pos) == "\r") && (hc_peek(s, (pos + 1)) == "\n")) then (pos + 2) else pos
  hc_parse_ml_basic_body(s, start, acc)

// .hc:509
pub fun hc_parse_ml_basic_escape(s : string, pos : int, acc : string)
  if ((pos + 1) >= s.count) then
    Left("unterminated escape in multi-line string")
  else
    val next : string = hc_peek(s, (pos + 1))
    if (next == "n") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ "\n"))
    else if (next == "t") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ "\t"))
    else if (next == "r") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ "\r"))
    else if (next == "b") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ 8.char.string))
    else if (next == "f") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ 12.char.string))
    else if (next == "\\") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ "\\"))
    else if (next == "\"") then
      hc_parse_ml_basic_body(s, (pos + 2), (acc ++ "\""))
    else if hc_is_newline(next) then hc_parse_ml_basic_body(s, hc_skip_ws_and_newlines(s, (pos + 1)), acc) else hc_parse_ml_basic_body(s, (pos + 2), ((acc ++ "\\") ++ next))

// .hc:525
pub fun hc_parse_ml_basic_body(s : string, pos : int, acc : string)
  if (pos >= s.count) then
    Left("unterminated multi-line string")
  else if hc_starts_with_at(s, pos, "\"\"\"") then
    Right((HStr(acc), (pos + 3)))
  else if (hc_peek(s, pos) == "\\") then hc_parse_ml_basic_escape(s, pos, acc) else hc_parse_ml_basic_body(s, (pos + 1), (acc ++ hc_peek(s, pos)))

// .hc:533
pub fun hc_parse_ml_literal_string(s : string, pos : int, acc : string)
  val start : int = if (hc_peek(s, pos) == "\n") then (pos + 1) else if ((hc_peek(s, pos) == "\r") && (hc_peek(s, (pos + 1)) == "\n")) then (pos + 2) else pos
  hc_parse_ml_literal_body(s, start, acc)

// .hc:539
pub fun hc_parse_ml_literal_body(s : string, pos : int, acc : string)
  if (pos >= s.count) then
    Left("unterminated multi-line literal string")
  else if hc_starts_with_at(s, pos, "\'\'\'") then Right((HStr(acc), (pos + 3))) else hc_parse_ml_literal_body(s, (pos + 1), (acc ++ hc_peek(s, pos)))

// .hc:551
pub fun hc_parse_element_name(s : string, pos : int, acc : string)
  match hc_parse_bare_key(s, pos, "")
    Right((k, p2)) ->
      val name = (acc ++ k)
      if (hc_peek(s, p2) == ".") then hc_parse_element_name(s, (p2 + 1), (name ++ ".")) else Right((name, p2))
    Left(e) ->
      Left(e)

// .hc:558
pub fun hc_parse_attributes(s : string, pos : int, attrs : list<(string, hml)>, text_elems : list<string>)
  val p1 : int = hc_skip_noise(s, pos)
  if (hc_peek(s, p1) == ")") then
    Right((attrs, (p1 + 1)))
  else
    match hc_parse_key(s, p1)
      Right((key, p2)) ->
        val p3 = hc_skip_ws(s, p2)
        if (hc_peek(s, p3) == ":") then
          val p4 : int = hc_skip_ws(s, (p3 + 1))
          match hc_parse_value(s, p4, text_elems)
            Right((hc_val, p5)) ->
              val p6 = hc_skip_noise(s, p5)
              if (hc_peek(s, p6) == ",") then hc_parse_attributes(s, (p6 + 1), (attrs ++ [(key, hc_val)]), text_elems) else hc_parse_attributes(s, p6, (attrs ++ [(key, hc_val)]), text_elems)
            Left(e) ->
              Left(e)
        else
          val p4 : int = hc_skip_noise(s, p3)
          if (hc_peek(s, p4) == ",") then hc_parse_attributes(s, (p4 + 1), (attrs ++ [(key, HBool(True))]), text_elems) else hc_parse_attributes(s, p4, (attrs ++ [(key, HBool(True))]), text_elems)
      Left(e) ->
        Left(e)

// .hc:595
pub fun hc_is_elem_named(node : hmlnode, name : string) : bool
  match node
    NElem(HElement(n, _, _)) ->
      (n == name)
    _ ->
      False

// .hc:599
pub fun hc_has_elem_named(nodes : list<hmlnode>, name : string)
  match nodes
    Nil ->
      False
    Cons(first, rest) ->
      if hc_is_elem_named(first, name) then True else hc_has_elem_named(rest, name)

// .hc:608
pub fun hc_add_if_missing(items : list<string>, item : string)
  if hc_list_contains(items, item) then items else (items ++ [item])

// .hc:612
pub fun hc_first_segment(segments : list<string>) : string
  match segments
    Cons(s, _) ->
      s
    _ ->
      ""

// .hc:615
pub fun hc_hml_elem_name(v : hml) : string
  match v
    HElement(n, _, _) ->
      n
    _ ->
      ""

// .hc:622
pub fun hc_merge_two_elems(existing : hmlnode, new_body : list<hmlnode>)
  match existing
    NElem(HElement(n, a, b)) ->
      NElem(HElement(n, a, hc_merge_body((b ++ new_body))))
    _ ->
      existing

// .hc:631
pub fun hc_try_merge_elem(nodes : list<hmlnode>, name : string, attrs : list<(string, hml)>, body : list<hmlnode>, checked : list<hmlnode>)
  match nodes
    Nil ->
      (checked ++ [NElem(HElement(name, attrs, body))])
    Cons(first, rest) ->
      if hc_is_elem_named(first, name) then ((checked ++ [hc_merge_two_elems(first, body)]) ++ rest) else hc_try_merge_elem(rest, name, attrs, body, (checked ++ [first]))

// .hc:643
pub fun hc_insert_or_merge(acc : list<hmlnode>, node : hmlnode)
  match node
    NElem(HElement(name, attrs, body)) ->
      hc_try_merge_elem(acc, name, attrs, body, [])
    _ ->
      (acc ++ [node])

// .hc:650
pub fun hc_merge_body_acc(remaining : list<hmlnode>, acc : list<hmlnode>)
  match remaining
    Nil ->
      acc
    Cons(node, rest) ->
      hc_merge_body_acc(rest, hc_insert_or_merge(acc, node))

// .hc:658
pub fun hc_merge_body(nodes : list<hmlnode>)
  hc_merge_body_acc(nodes, [])

// .hc:662
pub fun hc_parse_body(s : string, pos : int, nodes : list<hmlnode>, text_elems : list<string>, dotted_names : list<string>)
  val p1 : int = hc_skip_noise(s, pos)
  if (hc_peek(s, p1) == "}") then
    Right((nodes, (p1 + 1)))
  else if (hc_peek(s, p1) == "@") then
    match hc_parse_element(s, p1, text_elems)
      Right((elem, p2)) ->
        val ename = hc_hml_elem_name(elem)
        if hc_list_contains(dotted_names, ename) then
          Left((((("merge rule: cannot mix explicit @" ++ ename) ++ " with dotted key '") ++ ename) ++ ".*'"))
        else
          hc_parse_body(s, p2, (nodes ++ [NElem(elem)]), text_elems, dotted_names)
      Left(e) ->
        Left(e)
  else if (hc_peek(s, p1) == "") then
    Left("unterminated body (missing '}')")
  else
    match hc_parse_key_path(s, p1)
      Right((segments, p2)) ->
        val p3 = hc_skip_ws(s, p2)
        if (hc_peek(s, p3) == ":") then
          val p4 : int = hc_skip_ws(s, (p3 + 1))
          match hc_parse_value(s, p4, text_elems)
            Right((hc_val, p5)) ->
              val new_node = hc_wrap_dotted_value(segments, hc_val)
              val root = hc_first_segment(segments)
              if (((list/length(segments) > 1) && hc_has_elem_named(nodes, root)) && !(hc_list_contains(dotted_names, root))) then
                Left(((("merge rule: cannot mix dotted key '" ++ root) ++ ".*' with explicit @") ++ root))
              else if (list/length(segments) > 1) then
                hc_parse_body(s, p5, hc_insert_or_merge(nodes, new_node), text_elems, hc_add_if_missing(dotted_names, root))
              else
                hc_parse_body(s, p5, (nodes ++ [new_node]), text_elems, dotted_names)
            Left(e) ->
              Left(e)
        else
          Left(("expected ':' after key at position " ++ show(p3)))
      Left(_) ->
        Left(("unexpected content in body at position " ++ show(p1)))

// .hc:702
pub fun hc_is_text_elem(name : string, text_elems : list<string>)
  match text_elems
    Nil ->
      False
    Cons(x, rest) ->
      if (x == name) then True else hc_is_text_elem(name, rest)

// .hc:710
pub fun hc_collect_text_run(s : string, pos : int, acc : string, text_elems : list<string>)
  if (pos >= s.count) then
    (if (acc == "") then [] else [NText(acc)], pos)
  else if (hc_peek(s, pos) == "}") then
    (if (acc == "") then [] else [NText(acc)], pos)
  else if (hc_peek(s, pos) == "\n") then
    (if (acc == "") then [] else [NText(acc)], (pos + 1))
  else if (hc_peek(s, pos) == "@") then
    match hc_try_inline_element(s, pos, text_elems)
      Just((elem, p2)) ->
        val text_nodes = if (acc == "") then [] else [NText(acc)]
        val (rest_nodes, p3) = hc_collect_text_run(s, p2, "", text_elems)
        (((text_nodes ++ [NElem(elem)]) ++ rest_nodes), p3)
      Nothing ->
        hc_collect_text_run(s, (pos + 1), (acc ++ "@"), text_elems)
  else
    hc_collect_text_run(s, (pos + 1), (acc ++ hc_peek(s, pos)), text_elems)

// .hc:728
pub fun hc_try_inline_element(s : string, pos : int, text_elems : list<string>)
  val p1 : int = (pos + 1)
  match hc_parse_element_name(s, p1, "")
    Right((name, p2)) ->
      if (hc_peek(s, p2) == "(") then
        match hc_parse_attributes(s, (p2 + 1), [], text_elems)
          Right((attrs, p3)) ->
            if (hc_peek(s, p3) == "{") then
              match hc_parse_text_body(s, (p3 + 1), [], text_elems)
                Right((body, p4)) ->
                  Just((HElement(name, attrs, body), p4))
                Left(_) ->
                  Nothing
            else
              Just((HElement(name, attrs, []), p3))
          Left(_) ->
            Nothing
      else if (hc_peek(s, p2) == "{") then
        match hc_parse_text_body(s, (p2 + 1), [], text_elems)
          Right((body, p3)) ->
            Just((HElement(name, [], body), p3))
          Left(_) ->
            Nothing
      else
        Just((HElement(name, [], []), p2))
    Left(_) ->
      Nothing

// .hc:756
pub fun hc_try_text_property(s : string, pos : int, text_elems : list<string>)
  match hc_parse_bare_key(s, pos, "")
    Right((key, p2)) ->
      val p3 = hc_skip_ws(s, p2)
      if (hc_peek(s, p3) == ":") then
        val p4 : int = hc_skip_ws(s, (p3 + 1))
        match hc_parse_value(s, p4, text_elems)
          Right((hc_val, p5)) ->
            Just((NProp(key, hc_val), p5))
          Left(_) ->
            Nothing
      else
        Nothing
    Left(_) ->
      Nothing

// .hc:770
pub fun hc_parse_text_body(s : string, pos : int, nodes : list<hmlnode>, text_elems : list<string>)
  val p1 : int = hc_skip_ws(s, pos)
  if (p1 >= s.count) then
    Left("unterminated text body (missing '}')")
  else if (hc_peek(s, p1) == "}") then
    Right((nodes, (p1 + 1)))
  else if hc_is_newline(hc_peek(s, p1)) then
    hc_parse_text_body(s, (p1 + 1), nodes, text_elems)
  else if ((((p1 + 1) < s.count) && (hc_peek(s, p1) == "/")) && (hc_peek(s, (p1 + 1)) == "/")) then
    val p2 : int = hc_skip_to_eol(s, (p1 + 2))
    hc_parse_text_body(s, p2, nodes, text_elems)
  else if (hc_peek(s, p1) == "@") then
    match hc_parse_element(s, p1, text_elems)
      Right((elem, p2)) ->
        hc_parse_text_body(s, p2, (nodes ++ [NElem(elem)]), text_elems)
      Left(e) ->
        Left(e)
  else
    match hc_try_text_property(s, p1, text_elems)
      Just((prop, p2)) ->
        hc_parse_text_body(s, p2, (nodes ++ [prop]), text_elems)
      Nothing ->
        val (text_nodes, p2) = hc_collect_text_run(s, p1, "", text_elems)
        hc_parse_text_body(s, p2, (nodes ++ text_nodes), text_elems)

// .hc:799
pub fun hc_parse_element(s : string, pos : int, text_elems : list<string>)
  val p1 : int = (pos + 1)
  match hc_parse_element_name(s, p1, "")
    Right((name, p2)) ->
      val p3 = hc_skip_ws(s, p2)
      val hc__scrut = if (hc_peek(s, p3) == "(") then
        match hc_parse_attributes(s, (p3 + 1), [], text_elems)
          Right((attrs, p4)) ->
            Right((attrs, p4))
          Left(e) ->
            Left(e)
      else
        Right(([], p3))
      match hc__scrut
        Right((attrs, p4)) ->
          val p5 = hc_skip_ws(s, p4)
          if (hc_peek(s, p5) == "{") then
            if hc_is_text_elem(name, text_elems) then
              match hc_parse_text_body(s, (p5 + 1), [], text_elems)
                Right((body, p6)) ->
                  Right((HElement(name, attrs, body), p6))
                Left(e) ->
                  Left(e)
            else
              match hc_parse_body(s, (p5 + 1), [], text_elems, [])
                Right((body, p6)) ->
                  Right((HElement(name, attrs, body), p6))
                Left(e) ->
                  Left(e)
          else
            Right((HElement(name, attrs, []), p5))
        Left(e) ->
          Left(e)
    Left(e) ->
      Left(e)

// .hc:835
pub fun hc_parse_inline_element(s : string, pos : int, text_elems : list<string>)
  hc_parse_element(s, pos, text_elems)

// .hc:844
pub fun hc_parse_text_names(s : string, pos : int, names : list<string>)
  val p1 : int = hc_skip_ws(s, pos)
  if ((p1 >= s.count) || hc_is_newline(hc_peek(s, p1))) then
    (names, p1)
  else if (hc_peek(s, p1) == ",") then
    hc_parse_text_names(s, (p1 + 1), names)
  else
    match hc_parse_bare_key(s, p1, "")
      Right((name, p2)) ->
        hc_parse_text_names(s, p2, (names ++ [name]))
      Left(_) ->
        (names, p1)

// .hc:853
pub fun hc_parse_text_directive(s : string, pos : int)
  if !(hc_starts_with_at(s, pos, "#text")) then
    Nothing
  else
    val p1 : int = hc_skip_ws(s, (pos + 5))
    if (hc_peek(s, p1) == ":") then
      val (names, p2) = hc_parse_text_names(s, (p1 + 1), [])
      Just((names, p2))
    else
      Nothing

// .hc:872
pub fun hc_default_text_elems() : list<string>
  ["body", "p", "text"]

// .hc:874
pub fun hc_parse_document(s : string, pos : int, nodes : list<hmlnode>, text_elems : list<string>, dotted_names : list<string>)
  val p1 : int = hc_skip_noise(s, pos)
  if (p1 >= s.count) then
    Right(nodes)
  else if (hc_peek(s, p1) == "@") then
    match hc_parse_element(s, p1, text_elems)
      Right((elem, p2)) ->
        val ename = hc_hml_elem_name(elem)
        if hc_list_contains(dotted_names, ename) then
          Left((((("merge rule: cannot mix explicit @" ++ ename) ++ " with dotted key '") ++ ename) ++ ".*'"))
        else
          hc_parse_document(s, p2, (nodes ++ [NElem(elem)]), text_elems, dotted_names)
      Left(e) ->
        Left(e)
  else if (hc_peek(s, p1) == "#") then
    match hc_parse_namespace_directive(s, p1)
      Just((pfx, uri, p2)) ->
        hc_parse_document(s, p2, (nodes ++ [NNamespace(pfx, uri)]), text_elems, dotted_names)
      Nothing ->
        match hc_parse_text_directive(s, p1)
          Just((names, p2)) ->
            hc_parse_document(s, p2, nodes, (text_elems ++ names), dotted_names)
          Nothing ->
            val p2 = hc_skip_to_eol(s, p1)
            hc_parse_document(s, p2, nodes, text_elems, dotted_names)
  else
    match hc_parse_key_path(s, p1)
      Right((segments, p2)) ->
        val p3 = hc_skip_ws(s, p2)
        if (hc_peek(s, p3) == ":") then
          val p4 : int = hc_skip_ws(s, (p3 + 1))
          match hc_parse_value(s, p4, text_elems)
            Right((hc_val, p5)) ->
              val new_node = hc_wrap_dotted_value(segments, hc_val)
              val root = hc_first_segment(segments)
              if (((list/length(segments) > 1) && hc_has_elem_named(nodes, root)) && !(hc_list_contains(dotted_names, root))) then
                Left(((("merge rule: cannot mix dotted key '" ++ root) ++ ".*' with explicit @") ++ root))
              else if (list/length(segments) > 1) then
                hc_parse_document(s, p5, hc_insert_or_merge(nodes, new_node), text_elems, hc_add_if_missing(dotted_names, root))
              else
                hc_parse_document(s, p5, (nodes ++ [new_node]), text_elems, dotted_names)
            Left(e) ->
              Left(e)
        else
          Left(("expected ':' after key at position " ++ show(p3)))
      Left(_) ->
        Left(("unexpected content at position " ++ show(p1)))

// .hc:927
pub fun hc_hml_parse(input : string)
  hc_parse_document(input, 0, [], hc_default_text_elems(), [])

// .hc:937
pub fun hc_find_last_slash(s : string, pos : int, last_end : int)
  if (pos >= s.count) then last_end else if (hc_peek(s, pos) == "/") then hc_find_last_slash(s, (pos + 1), (pos + 1)) else hc_find_last_slash(s, (pos + 1), last_end)

// .hc:942
pub fun hc_dir_of_path(hc_path : string)
  hc_path.list.drop(0).take((hc_find_last_slash(hc_path, 0, 0)) - (0)).string

// .hc:943
pub fun hc_resolve_include_path(base_dir : string, rel : string) : string
  (base_dir ++ rel)

// .hc:947
pub fun hc_list_contains(items : list<string>, target : string)
  match items
    Nil ->
      False
    Cons(x, rest) ->
      if (x == target) then True else hc_list_contains(rest, target)

// .hc:954
pub fun hc_parse_include_path(s : string, pos : int)
  if !(hc_starts_with_at(s, pos, "#include")) then
    Nothing
  else
    val p1 : int = hc_skip_ws(s, (pos + 8))
    if (hc_peek(s, p1) == "\"") then
      match hc_parse_basic_string(s, (p1 + 1), "")
        Right((hc_path, p2)) ->
          Just((hc_path, p2))
        Left(_) ->
          Nothing
    else
      Nothing

// .hc:966
pub fun hc_parse_namespace_directive(s : string, pos : int)
  if !(hc_starts_with_at(s, pos, "#namespace")) then
    Nothing
  else
    val p1 : int = hc_skip_ws(s, (pos + 10))
    match hc_parse_bare_key(s, p1, "")
      Right((pfx, p2)) ->
        val p3 = hc_skip_ws(s, p2)
        if (hc_peek(s, p3) == ":") then
          val p4 : int = hc_skip_ws(s, (p3 + 1))
          if (hc_peek(s, p4) == "\"") then
            match hc_parse_basic_string(s, (p4 + 1), "")
              Right((uri, p5)) ->
                Just((pfx, uri, p5))
              Left(_) ->
                Nothing
          else
            Nothing
        else
          Nothing
      Left(_) ->
        Nothing

// .hc:990
pub fun hc_include_file_nodes(s : string, p2 : int, content : string, full_path : string, nodes : list<hmlnode>, base_dir : string, seen : list<string>, text_elems : list<string>, dotted_names : list<string>)
  val inc_base : string = hc_dir_of_path(full_path)
  match hc_parse_file_doc(content, 0, [], inc_base, (seen ++ [full_path]), text_elems, [])
    Right(inc_nodes) ->
      hc_parse_file_doc(s, hc_skip_to_eol(s, p2), (nodes ++ inc_nodes), base_dir, seen, text_elems, dotted_names)
    Left(e) ->
      Left(e)

// .hc:1002
pub fun hc_parse_file_doc(s : string, pos : int, nodes : list<hmlnode>, base_dir : string, seen : list<string>, text_elems : list<string>, dotted_names : list<string>)
  val p1 : int = hc_skip_noise(s, pos)
  if (p1 >= s.count) then
    Right(nodes)
  else if (hc_peek(s, p1) == "@") then
    match hc_parse_element(s, p1, text_elems)
      Right((elem, p2)) ->
        val ename = hc_hml_elem_name(elem)
        if hc_list_contains(dotted_names, ename) then
          Left((((("merge rule: cannot mix explicit @" ++ ename) ++ " with dotted key '") ++ ename) ++ ".*'"))
        else
          hc_parse_file_doc(s, p2, (nodes ++ [NElem(elem)]), base_dir, seen, text_elems, dotted_names)
      Left(e) ->
        Left(e)
  else if (hc_peek(s, p1) == "#") then
    match hc_parse_include_path(s, p1)
      Just((hc_path, p2)) ->
        val full_path = hc_resolve_include_path(base_dir, hc_path)
        if hc_list_contains(seen, full_path) then
          Left(("circular include: " ++ full_path))
        else
          match (match try({ read-text-file(full_path.path) }) { Ok(hc__c) -> Right(hc__c); Error(hc__e) -> Left(hc__e.message) })
            Right(content) ->
              hc_include_file_nodes(s, p2, content, full_path, nodes, base_dir, seen, text_elems, dotted_names)
            Left(_) ->
              Left(("cannot read included file: " ++ full_path))
      Nothing ->
        match hc_parse_namespace_directive(s, p1)
          Just((pfx, uri, p2)) ->
            hc_parse_file_doc(s, p2, (nodes ++ [NNamespace(pfx, uri)]), base_dir, seen, text_elems, dotted_names)
          Nothing ->
            match hc_parse_text_directive(s, p1)
              Just((names, p2)) ->
                hc_parse_file_doc(s, p2, nodes, base_dir, seen, (text_elems ++ names), dotted_names)
              Nothing ->
                hc_parse_file_doc(s, hc_skip_to_eol(s, p1), nodes, base_dir, seen, text_elems, dotted_names)
  else
    match hc_parse_key_path(s, p1)
      Right((segments, p2)) ->
        val p3 = hc_skip_ws(s, p2)
        if (hc_peek(s, p3) == ":") then
          val p4 : int = hc_skip_ws(s, (p3 + 1))
          match hc_parse_value(s, p4, text_elems)
            Right((hc_val, p5)) ->
              val new_node = hc_wrap_dotted_value(segments, hc_val)
              val root = hc_first_segment(segments)
              if (((list/length(segments) > 1) && hc_has_elem_named(nodes, root)) && !(hc_list_contains(dotted_names, root))) then
                Left(((("merge rule: cannot mix dotted key '" ++ root) ++ ".*' with explicit @") ++ root))
              else if (list/length(segments) > 1) then
                hc_parse_file_doc(s, p5, hc_insert_or_merge(nodes, new_node), base_dir, seen, text_elems, hc_add_if_missing(dotted_names, root))
              else
                hc_parse_file_doc(s, p5, (nodes ++ [new_node]), base_dir, seen, text_elems, dotted_names)
            Left(e) ->
              Left(e)
        else
          Left(("expected ':' after key at position " ++ show(p3)))
      Left(_) ->
        Left(("unexpected content at position " ++ show(p1)))

// .hc:1066
pub fun hc_hml_parse_file_content(content : string, hc_path : string)
  val base : string = hc_dir_of_path(hc_path)
  hc_parse_file_doc(content, 0, [], base, [hc_path], hc_default_text_elems(), [])

// .hc:1074
pub fun hc_hml_parse_file(hc_path : string)
  match (match try({ read-text-file(hc_path.path) }) { Ok(hc__c) -> Right(hc__c); Error(hc__e) -> Left(hc__e.message) })
    Right(content) ->
      hc_hml_parse_file_content(content, hc_path)
    Left(_) ->
      Left(("cannot read file: " ++ hc_path))
