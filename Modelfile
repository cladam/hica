type Shape {
  Circle(radius: float),
  Rect(width: float, height: float),
  Point
}

fun area(s: Shape) : float => match s {
  Circle(r)   => 3.14159 * r * r,
  Rect(w, h)  => w * h,
  Point       => 0.0
}
