    // --- Prelude string functions (inline definitions since check-diagnostics skips prelude files) ---

    dtest("unwords joins with space")
      val ds = check-diagnostics("fun unwords(ws) => join(ws, \" \")\nfun main() => println(unwords([\"a\", \"b\"]))")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("unlines joins with newline")
      val ds = check-diagnostics("fun unlines(ls) => join(ls, \"\\n\")\nfun main() => println(unlines([\"a\", \"b\"]))")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("count_substr type-checks")
      val ds = check-diagnostics("fun count_substr(s: string, sub: string) => length(split(s, sub)) - 1\nfun main() => println(show(count_substr(\"banana\", \"an\")))")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("center type-checks")
      val ds = check-diagnostics("fun max(a, b) => if a > b { a } else { b }\nfun repeat_str(s: string, n: int) : string => if n <= 0 { \"\" } else { s + repeat_str(s, n - 1) }\nfun center(s: string, width: int, ch: string) { let total = max(0, width - str_length(s)); let left = total / 2; let right = total - left; repeat_str(ch, left) + s + repeat_str(ch, right) }\nfun main() => println(center(\"hi\", 10, \"-\"))")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    // --- String indexing & slicing ---

    dtest("string index returns char")
      val ds = check-diagnostics("fun main() { let c = \"hello\"[0]; println(c) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("string index emits .list[i].unjust")
      val code = emit-typed-program("fun main() => \"hello\"[0]")
      assert/is-true(code.contains(".list["))
      assert/is-true(code.contains("].unjust"))

    dtest("string negative index emits .list.length")
      val code = emit-typed-program("fun main() => \"hello\"[-1]")
      assert/is-true(code.contains(".list.length"))

    dtest("string slice returns string")
      val ds = check-diagnostics("fun main() { let s = \"hello\"[1:3]; println(s + \"!\") }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("string slice emits .list.drop.take.string")
      val code = emit-typed-program("fun main() => \"hello\"[1:3]")
      assert/is-true(code.contains(".list.drop("))
      assert/is-true(code.contains(".string"))

    dtest("string slice start-only emits .list.drop.string")
      val code = emit-typed-program("fun main() => \"hello\"[2:]")
      assert/is-true(code.contains(".list.drop("))
      assert/is-true(code.contains(".string"))

    dtest("string slice end-only emits .list.take.string")
      val code = emit-typed-program("fun main() => \"hello\"[:3]")
      assert/is-true(code.contains(".list.take("))
      assert/is-true(code.contains(".string"))

    dtest("list indexing still works")
      val ds = check-diagnostics("fun main() { let xs = [1,2,3]; println(show(xs[0])) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("list slicing still works")
      val ds = check-diagnostics("fun main() { let xs = [1,2,3]; println(show(length(xs[1:]))) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    // --- String comparison ---

    dtest("string less-than type-checks")
      val ds = check-diagnostics("fun main() => \"alpha\" < \"beta\"")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("comparison"))
      assert/is-true(errors.length == 0)

    dtest("string greater-than type-checks")
      val ds = check-diagnostics("fun main() => \"beta\" > \"alpha\"")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("comparison"))
      assert/is-true(errors.length == 0)

    dtest("string comparison emits operator")
      val code = emit-typed-program("fun main() => \"alpha\" < \"beta\"")
      assert/is-true(code.contains("<"))

    dtest("string comparison returns bool")
      val ds = check-diagnostics("fun main() { let r = \"a\" < \"b\"; println(r && true) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- find(list, fn) ---

    dtest("find type-checks")
      val ds = check-diagnostics("fun main() => find([1, 2, 3], (x) => x > 2)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("find emits find call")
      val code = emit-typed-program("fun main() => find([1, 2, 3], (x) => x > 2)")
      assert/is-true(code.contains("find("))

    dtest("find returns maybe")
      val ds = check-diagnostics("fun main() { match find([1, 2, 3], (x) => x > 2) { Some(v) => println(v), None => println(0) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    // --- Structs ---
    dtest("struct emits Koka struct definition")
      val code = emit-typed-program("struct Point { x: int, y: int } fun main() => 0")
      assert/is-true(code.contains("struct point"))
      assert/is-true(code.contains("x : int"))
      assert/is-true(code.contains("y : int"))

    dtest("struct construction emits Koka constructor")
      val code = emit-typed-program("struct Point { x: int, y: int } fun main() => Point { x: 1, y: 2 }")
      assert/is-true(code.contains("Point(1, 2)"))

    dtest("struct field access emits dot accessor")
      val code = emit-typed-program("struct Point { x: int, y: int } fun main() { let p = Point { x: 3, y: 4 }; p.x }")
      assert/is-true(code.contains("p.x"))

    dtest("struct type-checks field types")
      val ds = check-diagnostics("struct Point { x: int, y: int } fun main() => Point { x: 1, y: 2 }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("struct rejects wrong field type")
      val ds = check-diagnostics("struct Point { x: int, y: int } fun main() => Point { x: true, y: 2 }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("struct rejects unknown field")
      val ds = check-diagnostics("struct Point { x: int, y: int } fun main() => Point { x: 1, z: 2 }")
      val errors = ds.filter(fn(d) d.message.contains("unknown field") || d.message.contains("missing field"))
      assert/is-true(errors.length > 0)

    dtest("struct rejects missing field")
      val ds = check-diagnostics("struct Point { x: int, y: int } fun main() => Point { x: 1 }")
      val errors = ds.filter(fn(d) d.message.contains("missing field"))
      assert/is-true(errors.length > 0)

    dtest("struct emits show function")
      val code = emit-typed-program("struct Point { x: int, y: int } fun main() => 0")
      assert/is-true(code.contains("fun point/show"))

    dtest("struct field access type-checks")
      val ds = check-diagnostics("struct Point { x: int, y: int } fun main() { let p = Point { x: 3, y: 4 }; p.x + p.y }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("struct can be used as function parameter")
      val code = emit-typed-program("struct Point { x: int, y: int } fun dist(p: Point) : int => p.x * p.x + p.y * p.y fun main() => dist(Point { x: 3, y: 4 })")
      assert/is-true(code.contains("p : point"))
      assert/is-true(code.contains("p.x"))

    // --- Match exhaustiveness checking ---
    dtest("exhaustive maybe match emits no warning")
      val ds = check-diagnostics("fun main() { let x = Some(1); match x { Some(n) => n, None => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("non-exhaustive maybe match missing None")
      val ds = check-diagnostics("fun main() { let x = Some(1); match x { Some(n) => n } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)
      assert/is-true(warns.head.unjust.message.contains("None"))

    dtest("non-exhaustive maybe match missing Some")
      val ds = check-diagnostics("fun main() { let x = Some(1); match x { None => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)
      assert/is-true(warns.head.unjust.message.contains("Some"))

    dtest("maybe match with wildcard is exhaustive")
      val ds = check-diagnostics("fun main() { let x = Some(1); match x { Some(n) => n, _ => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("maybe match with variable is exhaustive")
      val ds = check-diagnostics("fun main() { let x = Some(1); match x { Some(n) => n, other => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("exhaustive result match emits no warning")
      val ds = check-diagnostics("fun main() { let x = Ok(1); match x { Ok(n) => n, Err(e) => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("non-exhaustive result match missing Err")
      val ds = check-diagnostics("fun main() { let x = Ok(1); match x { Ok(n) => n } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)
      assert/is-true(warns.head.unjust.message.contains("Err"))

    dtest("non-exhaustive result match missing Ok")
      val ds = check-diagnostics("fun main() { let x = Ok(1); match x { Err(e) => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)
      assert/is-true(warns.head.unjust.message.contains("Ok"))

    dtest("non-exhaustive bool match missing false")
      val ds = check-diagnostics("fun main() { match true { true => 1 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)
      assert/is-true(warns.head.unjust.message.contains("false"))

    dtest("exhaustive bool match emits no warning")
      val ds = check-diagnostics("fun main() { match true { true => 1, false => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("non-exhaustive int match without wildcard")
      val ds = check-diagnostics("fun main() { match 1 { 1 => 10, 2 => 20 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)

    dtest("int match with wildcard is exhaustive")
      val ds = check-diagnostics("fun main() { match 1 { 1 => 10, _ => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    dtest("non-exhaustive string match without wildcard")
      val ds = check-diagnostics("fun main() { match \"hello\" { \"yes\" => 1, \"no\" => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length > 0)

    dtest("string match with variable is exhaustive")
      val ds = check-diagnostics("fun main() { match \"hello\" { \"yes\" => 1, s => 0 } }")
      val warns = ds.filter(fn(d) d.message.contains("non-exhaustive"))
      assert/is-true(warns.length == 0)

    // --- Structured diagnostic rendering ---
    dtest("render-diagnostic shows line and column")
      val src = "fun main() => 42 + \"hello\""
      val d = Diagnostic(Error, Span(15, 26), "type mismatch: expected int, got string")
      val out = render-diagnostic(src, "test.hc", d)
      assert/is-true(out.contains("error[test.hc:1:16]"))
      assert/is-true(out.contains("type mismatch"))
      assert/is-true(out.contains("1 |"))
      assert/is-true(out.contains("^^^^^^^^^^^"))

    dtest("render-diagnostic multiline source")
      val src = "fun add(a, b) => a + b\n\nfun main() {\n  add(1, \"two\")\n}"
      val d = Diagnostic(Error, Span(39, 52), "type mismatch")
      val out = render-diagnostic(src, "test.hc", d)
      assert/is-true(out.contains("error[test.hc:4:"))
      assert/is-true(out.contains("4 |"))

    dtest("render-diagnostic warning format")
      val src = "fun main() { match Some(1) { Some(n) => n } }"
      val d = Diagnostic(Warning, Span(13, 44), "non-exhaustive match: missing None")
      val out = render-diagnostic(src, "test.hc", d)
      assert/is-true(out.contains("warning[test.hc:1:"))
      assert/is-true(out.contains("non-exhaustive"))

    dtest("render-diagnostic no-span fallback")
      val d = Diagnostic(Error, Span(0, 0), "unknown error")
      val out = render-diagnostic("anything", "test.hc", d)
      assert/is-true(out.contains("error[test.hc]"))

    // --- Environment helpers ---
    dtest("get_args emits get-args()")
      val code = emit-typed-program("fun main() => get_args()")
      assert/is-true(code.contains("get-args()"))

    dtest("get_args type-checks as list<string>")
      val ds = check-diagnostics("fun main() => get_args()")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("get_args imports std/os/env")
      val code = emit-typed-program("fun main() => get_args()")
      assert/is-true(code.contains("import std/os/env"))

    dtest("get_env emits get-env-value")
      val code = emit-typed-program("fun main() => get_env(\"HOME\")")
      assert/is-true(code.contains("get-env-value"))

    dtest("get_env type-checks as maybe<string>")
      val ds = check-diagnostics("fun main() => get_env(\"HOME\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("get_env imports std/os/env")
      val code = emit-typed-program("fun main() => get_env(\"HOME\")")
      assert/is-true(code.contains("import std/os/env"))

    dtest("eprintln emits trace")
      val code = emit-typed-program("fun main() => eprintln(\"oops\")")
      assert/is-true(code.contains("trace("))

    dtest("eprintln type-checks without error")
      val ds = check-diagnostics("fun main() => eprintln(\"oops\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("eprintln auto-shows non-string")
      val code = emit-typed-program("fun main() => eprintln(42)")
      assert/is-true(code.contains(".show"))

    dtest("no env import when not using env functions")
      val code = emit-typed-program("fun main() => println(42)")
      assert/is-true(!code.contains("std/os/env"))

    // --- Or-patterns ---
    dtest("emit or-pattern with literals")
      val code = emit-typed-program("fun classify(x: int) => match x { 1 | 2 | 3 => true, _ => false }")
      assert/is-true(code.contains("1 | 2 | 3 ->"))

    dtest("emit or-pattern with two alternatives")
      val code = emit-typed-program("fun test(x: int) => match x { 0 | 1 => true, _ => false }")
      assert/is-true(code.contains("0 | 1 ->"))
