import kunit
import syntax/ast
import syntax/lexer
import syntax/parser
import emit/codegen

// Helper: parse then emit
fun emit-show( source : string ) : <div,console> string
  val tokens = lex(source)
  val ast = run-parser(tokens) { parse-expr() }
  emit(ast)

pub fun main() : io ()
  println(bold("Codegen tests"))
  println("")
  defaultKDivHandler
    dtest("emit integer literal")
      val code = emit-show("42")
      assert/is-true(code.contains("println(42.show)"))

    dtest("emit boolean literal")
      val code = emit-show("true")
      assert/is-true(code.contains("println(True.show)"))

    dtest("emit addition")
      val code = emit-show("1 + 2")
      assert/is-true(code.contains("(1 + 2)"))

    dtest("emit let binding")
      val code = emit-show("let x = 5; x")
      assert/is-true(code.contains("val x = 5"))
      assert/is-true(code.contains("x"))

    dtest("emit generates module header")
      val code = emit-show("42")
      assert/is-true(code.contains("// Generated by hica"))
      assert/is-true(code.contains("module main"))

    dtest("emit generates main function")
      val code = emit-show("42")
      assert/is-true(code.contains("fun main()"))

    dtest("emit if expression")
      val code = emit-show("if true { 1 } else { 2 }")
      assert/is-true(code.contains("if"))
      assert/is-true(code.contains("then"))
      assert/is-true(code.contains("else"))
