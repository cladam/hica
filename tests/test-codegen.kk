import kunit
import syntax/ast
import syntax/lexer
import syntax/parser
import semantics/checker
import diagnostics/diagnostics
import emit/codegen

// Helper: parse then emit (single expression)
fun emit-show( source : string ) : <div,console> string
  val tokens = lex(source)
  val ast = run-parser(tokens) { parse-expr() }
  emit(ast)

// Helper: parse then emit a full program
fun emit-program-show( source : string ) : <div,console> string
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  emit-program(prog)

// Helper: parse → check → emit a full program (typed pipeline)
fun emit-typed-program( source : string ) : <div,console> string
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  val (typed-prog, _) = collect-diagnostics
    run-fresh
      check-program(prog)
  emit-program(typed-prog)

// Helper: parse → check and return diagnostics
fun check-diagnostics( source : string ) : <div,console> list<diagnostic>
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  val (_, ds) = collect-diagnostics
    run-fresh
      check-program(prog)
  ds

pub fun main() : io ()
  println(bold("Codegen tests"))
  println("")
  defaultKDivHandler
    // --- Expression emission (existing) ---
    dtest("emit integer literal")
      val code = emit-show("42")
      assert/is-true(code.contains("println(42.show)"))

    dtest("emit boolean literal")
      val code = emit-show("true")
      assert/is-true(code.contains("println(True.show)"))

    dtest("emit string literal")
      val code = emit-show("\"hello\"")
      assert/is-true(code.contains("hello"))

    dtest("emit addition")
      val code = emit-show("1 + 2")
      assert/is-true(code.contains("(1 + 2)"))

    dtest("emit subtraction")
      val code = emit-show("10 - 5")
      assert/is-true(code.contains("(10 - 5)"))

    dtest("emit multiplication")
      val code = emit-show("3 * 4")
      assert/is-true(code.contains("(3 * 4)"))

    dtest("emit division")
      val code = emit-show("20 / 4")
      assert/is-true(code.contains("(20 / 4)"))

    dtest("emit equality")
      val code = emit-show("1 == 2")
      assert/is-true(code.contains("(1 == 2)"))

    dtest("emit inequality")
      val code = emit-show("1 != 2")
      assert/is-true(code.contains("(1 != 2)"))

    dtest("emit logical and")
      val code = emit-show("true && false")
      assert/is-true(code.contains("&&"))

    dtest("emit logical or")
      val code = emit-show("true || false")
      assert/is-true(code.contains("||"))

    dtest("emit let binding")
      val code = emit-show("let x = 5; x")
      assert/is-true(code.contains("val x = 5"))

    dtest("emit generates module header")
      val code = emit-show("42")
      assert/is-true(code.contains("// Generated by hica"))
      assert/is-true(code.contains("module main"))

    dtest("emit generates main function")
      val code = emit-show("42")
      assert/is-true(code.contains("fun main()"))

    dtest("emit if expression")
      val code = emit-show("if true { 1 } else { 2 }")
      assert/is-true(code.contains("if"))
      assert/is-true(code.contains("then"))
      assert/is-true(code.contains("else"))

    dtest("emit negation")
      val code = emit-show("-42")
      assert/is-true(code.contains("(0 - 42)"))

    dtest("emit logical not")
      val code = emit-show("!true")
      assert/is-true(code.contains("!(True)"))

    dtest("emit parenthesized expression")
      val code = emit-show("(1 + 2) * 3")
      assert/is-true(code.contains("((1 + 2) * 3)"))

    // --- Function call emission (new) ---
    dtest("emit function call no args")
      val code = emit-show("f()")
      assert/is-true(code.contains("f()"))

    dtest("emit function call with args")
      val code = emit-show("f(1, 2)")
      assert/is-true(code.contains("f(1, 2)"))

    // --- Match expression emission (new) ---
    dtest("emit match expression")
      val code = emit-show("match x { 1 => 10, _ => 0 }")
      assert/is-true(code.contains("match x"))
      assert/is-true(code.contains("-> 10"))
      assert/is-true(code.contains("_ -> 0"))

    // --- Program emission (new, inspired by lisette) ---
    dtest("emit simple program")
      val code = emit-program-show("fun main() { 42 }")
      assert/is-true(code.contains("// Generated by hica"))
      assert/is-true(code.contains("module main"))
      assert/is-true(code.contains("fun main()"))
      assert/is-true(code.contains("42"))

    dtest("emit function with return type")
      val code = emit-program-show("fun get_value() { 42 }")
      assert/is-true(code.contains("fun hc_get_value()"))
      assert/is-true(code.contains("42"))

    dtest("emit function with parameters")
      val code = emit-program-show("fun add(a, b) => a + b")
      assert/is-true(code.contains("fun hc_add(a, b)"))
      assert/is-true(code.contains("(a + b)"))

    dtest("emit arrow function declaration")
      val code = emit-program-show("fun double(x) => x * 2")
      assert/is-true(code.contains("fun hc_double(x)"))
      assert/is-true(code.contains("(x * 2)"))

    dtest("emit multiple function declarations")
      val code = emit-program-show("fun double(x) => x * 2\nfun main() { double(21) }")
      assert/is-true(code.contains("fun hc_double(x)"))
      assert/is-true(code.contains("fun main()"))
      assert/is-true(code.contains("hc_double(21)"))

    dtest("emit function with let binding in body")
      val code = emit-program-show("fun main() { let x = 42; x }")
      assert/is-true(code.contains("val x = 42"))

    dtest("emit function with if expression in body")
      val code = emit-program-show("fun test(x) { if x { 1 } else { 2 } }")
      assert/is-true(code.contains("fun hc_test(x)"))
      assert/is-true(code.contains("if"))

    dtest("emit function with match in body")
      val code = emit-program-show("fun test(x) { match x { 1 => 10, _ => 0 } }")
      assert/is-true(code.contains("match x"))

    // --- Repeat emission ---
    dtest("emit repeat expression")
      val code = emit-show("repeat(3) { 42 }")
      assert/is-true(code.contains("repeat(3)"))

    dtest("emit repeat in program")
      val code = emit-program-show("fun main() { repeat(5) { 42 } }")
      assert/is-true(code.contains("repeat(5)"))
      assert/is-true(code.contains("42"))

    // --- String concatenation ---
    dtest("emit string concat uses ++")
      val code = emit-typed-program("fun main() { \"hello\" + \" world\" }")
      assert/is-true(code.contains("++"))

    dtest("emit int addition still uses +")
      val code = emit-typed-program("fun main() { 1 + 2 }")
      assert/is-true(code.contains("(1 + 2)"))

    // --- String literal patterns ---
    dtest("emit match with string patterns")
      val code = emit-program-show("fun test(s) { match s { \"yes\" => 1, \"no\" => 0, _ => -1 } }")
      assert/is-true(code.contains("match"))
      assert/is-true(code.contains("\"yes\""))
      assert/is-true(code.contains("\"no\""))

    // --- String interpolation ---
    dtest("emit interpolation with variable")
      val code = emit-typed-program("fun greet(name) { \"hello {name}!\" }")
      assert/is-true(code.contains("++"))
      assert/is-true(code.contains("\"hello \""))
      assert/is-true(code.contains("\"!\""))

    dtest("emit interpolation with int expression uses show")
      val code = emit-typed-program("fun show_score(n) { \"score: {n + 1}\" }")
      assert/is-true(code.contains("int/show"))
      assert/is-true(code.contains("\"score: \""))

    dtest("emit interpolation string literal no show")
      val code = emit-typed-program("fun main() { let name = \"world\"; \"hello {name}!\" }")
      assert/is-true(code.contains("++"))
      // name is inferred as string from the literal — should NOT have .show
      assert/is-true(!code.contains(".show"))

    // --- Float literals ---
    dtest("emit float literal")
      val code = emit-typed-program("fun main() => 3.14")
      assert/is-true(code.contains("3.14"))

    dtest("emit float program imports float64")
      val code = emit-typed-program("fun main() => 3.14")
      assert/is-true(code.contains("import std/num/float64"))

    dtest("emit int program no float64 import")
      val code = emit-typed-program("fun main() => 42")
      assert/is-true(!code.contains("float64"))

    dtest("emit float arithmetic")
      val code = emit-typed-program("fun main() => 1.5 + 2.5")
      assert/is-true(code.contains("1.5"))
      assert/is-true(code.contains("2.5"))

    // --- Tuples ---
    dtest("emit tuple literal")
      val code = emit-typed-program("fun main() => (1, 2)")
      assert/is-true(code.contains("(1, 2)"))

    dtest("emit tuple index fst")
      val code = emit-typed-program("fun main() { let t = (1, 2); t.0 }")
      assert/is-true(code.contains(".fst"))

    dtest("emit tuple index snd")
      val code = emit-typed-program("fun main() { let t = (1, 2); t.1 }")
      assert/is-true(code.contains(".snd"))

    dtest("emit tuple destructuring")
      val code = emit-typed-program("fun main() { let (a, b) = (1, 2); a }")
      assert/is-true(code.contains("val (a, b)"))

    dtest("error on tuple with more than 5 elements")
      val ds = check-diagnostics("fun main() { (1, 2, 3, 4, 5, 6) }")
      assert/is-true(ds.length > 0)
      assert/is-true(ds.head.default(Diagnostic(Info, Span(0,0), "")).message.contains("at most 5"))

    dtest("no error on tuple with 5 elements")
      val ds = check-diagnostics("fun main() { (1, 2, 3, 4, 5) }")
      val tuple-errors = ds.filter(fn(d) d.message.contains("at most 5"))
      assert/is-true(tuple-errors.length == 0)

    // --- Prelude: built-in stdlib functions ---
    dtest("println no undefined variable error")
      val ds = check-diagnostics("fun main() { println(\"hello\") }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("show no undefined variable error")
      val ds = check-diagnostics("fun main() { show(42) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("abs no undefined variable error")
      val ds = check-diagnostics("fun main() { abs(-5) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("min no undefined variable error")
      val ds = check-diagnostics("fun main() { min(1, 2) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("max no undefined variable error")
      val ds = check-diagnostics("fun main() { max(1, 2) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("println passes through to Koka (no hc_ prefix)")
      val code = emit-typed-program("fun main() { println(\"hi\") }")
      assert/is-true(code.contains("println(\"hi\")"))
      assert/is-true(!code.contains("hc_println"))

    dtest("unknown variable still reports error")
      val ds = check-diagnostics("fun main() { unknown_func(1) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length > 0)
