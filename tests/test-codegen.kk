import kunit
import syntax/ast
import syntax/lexer
import syntax/parser
import semantics/checker
import diagnostics/diagnostics
import emit/codegen
import transform/desugar

// Helper: parse then emit (single expression)
fun emit-show( source : string ) : <div,console> string
  val tokens = lex(source)
  val ast = run-parser(tokens) { parse-expr() }
  emit(ast)

// Helper: parse then emit a full program
fun emit-program-show( source : string ) : <div,console> string
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  emit-program(prog)

// Helper: parse → check → emit a full program (typed pipeline)
fun emit-typed-program( source : string ) : <div,console> string
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  val desugared = desugar-program(prog)
  val (typed-prog, _) = collect-diagnostics
    run-fresh
      check-program(desugared)
  emit-program(typed-prog)

// Helper: parse → check and return diagnostics
fun check-diagnostics( source : string ) : <div,console> list<diagnostic>
  val tokens = lex(source)
  val prog = run-parser-program(tokens)
  val desugared = desugar-program(prog)
  val (_, ds) = collect-diagnostics
    run-fresh
      check-program(desugared)
  ds

pub fun main() : io ()
  println(bold("Codegen tests"))
  println("")
  defaultKDivHandler
    // --- Expression emission (existing) ---
    dtest("emit integer literal")
      val code = emit-show("42")
      assert/is-true(code.contains("println(42.show)"))

    dtest("emit boolean literal")
      val code = emit-show("true")
      assert/is-true(code.contains("println(True.show)"))

    dtest("emit string literal")
      val code = emit-show("\"hello\"")
      assert/is-true(code.contains("hello"))

    dtest("emit addition")
      val code = emit-show("1 + 2")
      assert/is-true(code.contains("(1 + 2)"))

    dtest("emit subtraction")
      val code = emit-show("10 - 5")
      assert/is-true(code.contains("(10 - 5)"))

    dtest("emit multiplication")
      val code = emit-show("3 * 4")
      assert/is-true(code.contains("(3 * 4)"))

    dtest("emit division")
      val code = emit-show("20 / 4")
      assert/is-true(code.contains("(20 / 4)"))

    dtest("emit equality")
      val code = emit-show("1 == 2")
      assert/is-true(code.contains("(1 == 2)"))

    dtest("emit inequality")
      val code = emit-show("1 != 2")
      assert/is-true(code.contains("(1 != 2)"))

    dtest("emit logical and")
      val code = emit-show("true && false")
      assert/is-true(code.contains("&&"))

    dtest("emit logical or")
      val code = emit-show("true || false")
      assert/is-true(code.contains("||"))

    dtest("emit let binding")
      val code = emit-show("let x = 5; x")
      assert/is-true(code.contains("val x = 5"))

    dtest("emit generates module header")
      val code = emit-show("42")
      assert/is-true(code.contains("// Generated by hica"))
      assert/is-true(code.contains("module main"))

    dtest("emit generates main function")
      val code = emit-show("42")
      assert/is-true(code.contains("fun main()"))

    dtest("emit if expression")
      val code = emit-show("if true { 1 } else { 2 }")
      assert/is-true(code.contains("if"))
      assert/is-true(code.contains("then"))
      assert/is-true(code.contains("else"))

    dtest("emit negation")
      val code = emit-show("-42")
      assert/is-true(code.contains("(0 - 42)"))

    dtest("emit logical not")
      val code = emit-show("!true")
      assert/is-true(code.contains("!(True)"))

    dtest("emit parenthesized expression")
      val code = emit-show("(1 + 2) * 3")
      assert/is-true(code.contains("((1 + 2) * 3)"))

    // --- Function call emission (new) ---
    dtest("emit function call no args")
      val code = emit-show("f()")
      assert/is-true(code.contains("f()"))

    dtest("emit function call with args")
      val code = emit-show("f(1, 2)")
      assert/is-true(code.contains("f(1, 2)"))

    // --- Match expression emission (new) ---
    dtest("emit match expression")
      val code = emit-show("match x { 1 => 10, _ => 0 }")
      assert/is-true(code.contains("match x"))
      assert/is-true(code.contains("1 ->"))
      assert/is-true(code.contains("10"))
      assert/is-true(code.contains("_ ->"))
      assert/is-true(code.contains("0"))

    // --- Match guards ---
    dtest("emit match guard")
      val code = emit-typed-program("fun classify(n) => match n { x if x < 0 => -1, _ => 1 }")
      assert/is-true(code.contains("|"))
      assert/is-true(code.contains("->"))

    dtest("emit match guard with constructor")
      val code = emit-typed-program("fun try_it(v) { match parse_int(v) { Some(n) if n < 0 => 0, Some(n) => n, None => -1 } }")
      assert/is-true(code.contains("|"))
      assert/is-true(code.contains("Just"))

    dtest("emit match without guard no pipe")
      val code = emit-typed-program("fun try_it(x) => match x { 0 => 1, _ => 2 }")
      assert/is-true(!code.contains("|"))

    dtest("match guard type-checks as bool")
      val ds = check-diagnostics("fun try_it(n) => match n { x if x + 1 => x, _ => 0 }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    // --- Program emission (new, inspired by lisette) ---
    dtest("emit simple program")
      val code = emit-program-show("fun main() { 42 }")
      assert/is-true(code.contains("// Generated by hica"))
      assert/is-true(code.contains("module main"))
      assert/is-true(code.contains("fun main()"))
      assert/is-true(code.contains("42"))

    dtest("emit function with return type")
      val code = emit-program-show("fun get_value() { 42 }")
      assert/is-true(code.contains("fun hc_get_value()"))
      assert/is-true(code.contains("42"))

    dtest("emit function with parameters")
      val code = emit-program-show("fun add(a, b) => a + b")
      assert/is-true(code.contains("fun hc_add(a, b)"))
      assert/is-true(code.contains("(a + b)"))

    dtest("emit arrow function declaration")
      val code = emit-program-show("fun double(x) => x * 2")
      assert/is-true(code.contains("fun hc_double(x)"))
      assert/is-true(code.contains("(x * 2)"))

    dtest("emit multiple function declarations")
      val code = emit-program-show("fun double(x) => x * 2\nfun main() { double(21) }")
      assert/is-true(code.contains("fun hc_double(x)"))
      assert/is-true(code.contains("fun main()"))
      assert/is-true(code.contains("hc_double(21)"))

    dtest("emit function with let binding in body")
      val code = emit-program-show("fun main() { let x = 42; x }")
      assert/is-true(code.contains("val x = 42"))

    dtest("emit function with if expression in body")
      val code = emit-program-show("fun try_it(x) { if x { 1 } else { 2 } }")
      assert/is-true(code.contains("fun hc_try_it(x)"))
      assert/is-true(code.contains("if"))

    dtest("emit function with match in body")
      val code = emit-program-show("fun try_it(x) { match x { 1 => 10, _ => 0 } }")
      assert/is-true(code.contains("match x"))

    // --- Repeat emission ---
    dtest("emit repeat expression")
      val code = emit-show("repeat(3) { 42 }")
      assert/is-true(code.contains("repeat(3)"))

    dtest("emit repeat in program")
      val code = emit-program-show("fun main() { repeat(5) { 42 } }")
      assert/is-true(code.contains("repeat(5)"))
      assert/is-true(code.contains("42"))

    // --- String concatenation ---
    dtest("emit string concat uses ++")
      val code = emit-typed-program("fun main() { \"hello\" + \" world\" }")
      assert/is-true(code.contains("++"))

    dtest("emit int addition still uses +")
      val code = emit-typed-program("fun main() { 1 + 2 }")
      assert/is-true(code.contains("(1 + 2)"))

    // --- String literal patterns ---
    dtest("emit match with string patterns")
      val code = emit-program-show("fun try_it(s) { match s { \"yes\" => 1, \"no\" => 0, _ => -1 } }")
      assert/is-true(code.contains("match"))
      assert/is-true(code.contains("\"yes\""))
      assert/is-true(code.contains("\"no\""))

    // --- String interpolation ---
    dtest("emit interpolation with variable")
      val code = emit-typed-program("fun greet(name) { \"hello {name}!\" }")
      assert/is-true(code.contains("++"))
      assert/is-true(code.contains("\"hello \""))
      assert/is-true(code.contains("\"!\""))

    dtest("emit interpolation with int expression uses show")
      val code = emit-typed-program("fun show_score(n) { \"score: {n + 1}\" }")
      assert/is-true(code.contains("int/show"))
      assert/is-true(code.contains("\"score: \""))

    dtest("emit interpolation string literal no show")
      val code = emit-typed-program("fun main() { let name = \"world\"; \"hello {name}!\" }")
      assert/is-true(code.contains("++"))
      // name is inferred as string from the literal — should NOT have .show
      assert/is-true(!code.contains(".show"))

    // --- Float literals ---
    dtest("emit float literal")
      val code = emit-typed-program("fun main() => 3.14")
      assert/is-true(code.contains("3.14"))

    dtest("emit float program imports float64")
      val code = emit-typed-program("fun main() => 3.14")
      assert/is-true(code.contains("import std/num/float64"))

    dtest("emit int program no float64 import")
      val code = emit-typed-program("fun main() => 42")
      assert/is-true(!code.contains("float64"))

    dtest("emit float arithmetic")
      val code = emit-typed-program("fun main() => 1.5 + 2.5")
      assert/is-true(code.contains("1.5"))
      assert/is-true(code.contains("2.5"))

    // --- Tuples ---
    dtest("emit tuple literal")
      val code = emit-typed-program("fun main() => (1, 2)")
      assert/is-true(code.contains("(1, 2)"))

    dtest("emit tuple index fst")
      val code = emit-typed-program("fun main() { let t = (1, 2); t.0 }")
      assert/is-true(code.contains(".fst"))

    dtest("emit tuple index snd")
      val code = emit-typed-program("fun main() { let t = (1, 2); t.1 }")
      assert/is-true(code.contains(".snd"))

    dtest("emit tuple destructuring")
      val code = emit-typed-program("fun main() { let (a, b) = (1, 2); a }")
      assert/is-true(code.contains("val (a, b)"))

    dtest("error on tuple with more than 5 elements")
      val ds = check-diagnostics("fun main() { (1, 2, 3, 4, 5, 6) }")
      assert/is-true(ds.length > 0)
      assert/is-true(ds.head.default(Diagnostic(Info, Span(0,0), "")).message.contains("at most 5"))

    dtest("no error on tuple with 5 elements")
      val ds = check-diagnostics("fun main() { (1, 2, 3, 4, 5) }")
      val tuple-errors = ds.filter(fn(d) d.message.contains("at most 5"))
      assert/is-true(tuple-errors.length == 0)

    dtest("emit tuple pattern in match")
      val code = emit-typed-program("fun main() { let t = (1, 2); match t { (a, b) => a } }")
      assert/is-true(code.contains("(a, b)"))

    dtest("emit tuple pattern with wildcard")
      val code = emit-typed-program("fun main() { let t = (1, 2); match t { (_, b) => b } }")
      assert/is-true(code.contains("(_, b)"))

    dtest("emit triple pattern in match")
      val code = emit-typed-program("fun main() { let t = (1, 2, 3); match t { (a, b, c) => a } }")
      assert/is-true(code.contains("(a, b, c)"))

    // --- Prelude: built-in stdlib functions ---
    dtest("println no undefined variable error")
      val ds = check-diagnostics("fun main() { println(\"hello\") }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("show no undefined variable error")
      val ds = check-diagnostics("fun main() { show(42) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("abs no undefined variable error")
      val ds = check-diagnostics("fun abs(n) => if n < 0 { -n } else { n }\nfun main() { abs(-5) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("min no undefined variable error")
      val ds = check-diagnostics("fun min(a, b) => if a < b { a } else { b }\nfun main() { min(1, 2) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("max no undefined variable error")
      val ds = check-diagnostics("fun max(a, b) => if a > b { a } else { b }\nfun main() { max(1, 2) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length == 0)

    dtest("println passes through to Koka (no hc_ prefix)")
      val code = emit-typed-program("fun main() { println(\"hi\") }")
      assert/is-true(code.contains("println(\"hi\")"))
      assert/is-true(!code.contains("hc_println"))

    dtest("unknown variable still reports error")
      val ds = check-diagnostics("fun main() { unknown_func(1) }")
      val undef = ds.filter(fn(d) d.message.contains("undefined variable"))
      assert/is-true(undef.length > 0)

    // --- Modulo operator ---
    dtest("emit modulo operator")
      val code = emit-typed-program("fun main() => 10 % 3")
      assert/is-true(code.contains("(10 % 3)"))

    dtest("modulo type checks as int")
      val ds = check-diagnostics("fun main() => 10 % 3")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- Lists ---
    dtest("emit empty list")
      val code = emit-typed-program("fun main() => []")
      assert/is-true(code.contains("[]"))

    dtest("emit list literal")
      val code = emit-typed-program("fun main() => [1, 2, 3]")
      assert/is-true(code.contains("[1, 2, 3]"))

    dtest("list elements type unify")
      val ds = check-diagnostics("fun main() => [1, 2, 3]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("list mixed types reports error")
      val ds = check-diagnostics("fun main() => [1, true]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    // --- println auto-show ---
    dtest("println auto-wraps int with show")
      val code = emit-typed-program("fun main() { println(42) }")
      assert/is-true(code.contains("println(42.show)"))

    dtest("println string arg unchanged")
      val code = emit-typed-program("fun main() { println(\"hi\") }")
      assert/is-true(code.contains("println(\"hi\")"))

    dtest("println list auto-wraps with show")
      val code = emit-typed-program("fun main() { println([1, 2]) }")
      assert/is-true(code.contains("println([1, 2].show)"))

    dtest("println int no type error")
      val ds = check-diagnostics("fun main() { println(42) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("show accepts any type")
      val ds = check-diagnostics("fun main() { println(show(true)) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- map / filter / fold ---
    dtest("map type-checks")
      val ds = check-diagnostics("fun main() => map([1, 2, 3], (x) => x + 1)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("map emits map call")
      val code = emit-typed-program("fun main() => map([1, 2, 3], (x) => x + 1)")
      assert/is-true(code.contains("map("))

    dtest("filter type-checks")
      val ds = check-diagnostics("fun main() => filter([1, 2, 3], (x) => x > 1)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("filter emits filter call")
      val code = emit-typed-program("fun main() => filter([1, 2, 3], (x) => x > 1)")
      assert/is-true(code.contains("filter("))

    dtest("fold type-checks")
      val ds = check-diagnostics("fun main() => fold([1, 2, 3], 0, (acc, x) => acc + x)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("fold emits foldl")
      val code = emit-typed-program("fun main() => fold([1, 2, 3], 0, (acc, x) => acc + x)")
      assert/is-true(code.contains("foldl("))

    // --- For loop ---
    dtest("for-in emits Koka for")
      val code = emit-typed-program("fun main() { for i in 0..10 { println(i) } }")
      assert/is-true(code.contains("for(0, 10)"))

    dtest("for-in loop variable in body")
      val code = emit-typed-program("fun main() { for i in 1..5 { println(i) } }")
      assert/is-true(code.contains("fn(i)"))

    dtest("for-in type-checks start and end as int")
      val ds = check-diagnostics("fun main() { for i in 0..10 { println(i) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("for-in loop variable is int")
      val ds = check-diagnostics("fun main() { for i in 0..10 { println(i + 1) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- While loop ---
    dtest("while emits Koka while")
      val code = emit-typed-program("fun main() { while true { println(42) } }")
      assert/is-true(code.contains("while"))

    dtest("while condition must be bool")
      val ds = check-diagnostics("fun main() { while 42 { println(0) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("while with bool condition type-checks")
      val ds = check-diagnostics("fun main() { while true { println(0) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- Var declarations and assignment ---
    dtest("var emits Koka var")
      val code = emit-typed-program("fun main() { var x = 10; println(x) }")
      assert/is-true(code.contains("var x"))
      assert/is-true(code.contains(":="))

    dtest("var type-checks correctly")
      val ds = check-diagnostics("fun main() { var x = 10; println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("assignment emits :=")
      val code = emit-typed-program("fun main() { var x = 10; x = 5; println(x) }")
      assert/is-true(code.contains("x := 5"))

    dtest("var with while loop type-checks")
      val ds = check-diagnostics("fun main() { var x = 5; while x > 0 { println(x); x = x - 1 } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- length / reverse / take / drop / zip / concat / any / all / foreach ---
    dtest("length type-checks")
      val ds = check-diagnostics("fun main() => length([1, 2, 3])")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("length emits length call")
      val code = emit-typed-program("fun main() => length([1, 2, 3])")
      assert/is-true(code.contains("length("))

    dtest("reverse type-checks")
      val ds = check-diagnostics("fun main() => reverse([1, 2, 3])")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("reverse emits reverse call")
      val code = emit-typed-program("fun main() => reverse([1, 2, 3])")
      assert/is-true(code.contains("reverse("))

    dtest("take type-checks")
      val ds = check-diagnostics("fun main() => take([1, 2, 3], 2)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("take emits take call")
      val code = emit-typed-program("fun main() => take([1, 2, 3], 2)")
      assert/is-true(code.contains("take("))

    dtest("drop type-checks")
      val ds = check-diagnostics("fun main() => drop([1, 2, 3], 1)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("drop emits drop call")
      val code = emit-typed-program("fun main() => drop([1, 2, 3], 1)")
      assert/is-true(code.contains("drop("))

    dtest("zip type-checks")
      val ds = check-diagnostics("fun main() => zip([1, 2], [\"a\", \"b\"])")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("zip emits zip call")
      val code = emit-typed-program("fun main() => zip([1, 2], [\"a\", \"b\"])")
      assert/is-true(code.contains("zip("))

    dtest("concat type-checks")
      val ds = check-diagnostics("fun main() => concat([[1, 2], [3, 4]])")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("concat emits concat call")
      val code = emit-typed-program("fun main() => concat([[1, 2], [3, 4]])")
      assert/is-true(code.contains("concat("))

    dtest("any type-checks")
      val ds = check-diagnostics("fun main() => any([1, 2, 3], (x) => x > 2)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("any emits any call")
      val code = emit-typed-program("fun main() => any([1, 2, 3], (x) => x > 2)")
      assert/is-true(code.contains("any("))

    dtest("all type-checks")
      val ds = check-diagnostics("fun main() => all([1, 2, 3], (x) => x > 0)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("all emits all call")
      val code = emit-typed-program("fun main() => all([1, 2, 3], (x) => x > 0)")
      assert/is-true(code.contains("all("))

    dtest("foreach type-checks")
      val ds = check-diagnostics("fun main() { foreach([1, 2, 3], (x) => println(x)) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("foreach emits foreach call")
      val code = emit-typed-program("fun main() { foreach([1, 2, 3], (x) => println(x)) }")
      assert/is-true(code.contains("foreach("))

    // --- List indexing ---
    dtest("list index type-checks")
      val ds = check-diagnostics("fun main() => [10, 20, 30][1]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("list index emits bracket syntax")
      val code = emit-typed-program("fun main() => [10, 20, 30][1]")
      assert/is-true(code.contains("[10, 20, 30][1].unjust"))

    dtest("list index returns element type")
      val ds = check-diagnostics("fun main() { let x = [1, 2, 3][0]; println(x + 1) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("list index with variable")
      val code = emit-typed-program("fun main() { let nums = [1, 2, 3]; println(nums[0]) }")
      assert/is-true(code.contains("nums[0].unjust"))

    // --- List slicing ---
    dtest("list slice start:end type-checks")
      val ds = check-diagnostics("fun main() => [1, 2, 3, 4][1:3]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("list slice start:end emits drop/take")
      val code = emit-typed-program("fun main() => [1, 2, 3, 4][1:3]")
      assert/is-true(code.contains(".drop("))
      assert/is-true(code.contains(".take("))

    dtest("list slice :end emits take")
      val code = emit-typed-program("fun main() => [1, 2, 3, 4][:2]")
      assert/is-true(code.contains(".take(2)"))

    dtest("list slice start: emits drop")
      val code = emit-typed-program("fun main() => [1, 2, 3, 4][2:]")
      assert/is-true(code.contains(".drop(2)"))

    dtest("list slice returns list type")
      val ds = check-diagnostics("fun main() { let xs = [1, 2, 3][1:2]; println(length(xs)) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("list slice negative end emits length adjustment")
      val code = emit-typed-program("fun main() => [1, 2, 3, 4, 5][1:-1]")
      assert/is-true(code.contains("list/length"))

    dtest("list slice negative start emits length adjustment")
      val code = emit-typed-program("fun main() => [1, 2, 3, 4, 5][-3:]")
      assert/is-true(code.contains("list/length"))

    // --- Recursion ---
    dtest("recursive function type-checks without error")
      val ds = check-diagnostics("fun factorial(n) => if n <= 1 { 1 } else { n * factorial(n - 1) }\nfun main() => factorial(5)")
      val errors = ds.filter(fn(d) d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("recursive function omits return annotation for div")
      val code = emit-typed-program("fun factorial(n) => if n <= 1 { 1 } else { n * factorial(n - 1) }\nfun main() => factorial(5)")
      // Should emit factorial without return type annotation so Koka infers div
      assert/is-true(code.contains("fun hc_factorial("))
      assert/is-true(code.contains("hc_factorial("))

    dtest("non-recursive function still emits return annotation")
      val code = emit-typed-program("fun double(x) => x * 2\nfun main() => double(3)")
      assert/is-true(code.contains(": int"))

    // --- enumerate ---
    dtest("enumerate type-checks")
      val ds = check-diagnostics("fun main() => enumerate([10, 20, 30])")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("cannot be found"))
      assert/is-true(errors.length == 0)

    dtest("enumerate emits map-indexed")
      val code = emit-typed-program("fun main() => enumerate([10, 20, 30])")
      assert/is-true(code.contains("map-indexed"))

    // --- list concat with + ---
    dtest("list + list type-checks")
      val ds = check-diagnostics("fun main() => [1, 2] + [3, 4]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("requires"))
      assert/is-true(errors.length == 0)

    dtest("list + list emits ++")
      val code = emit-typed-program("fun main() => [1, 2] + [3, 4]")
      assert/is-true(code.contains("++"))

    dtest("list + non-list reports error")
      val ds = check-diagnostics("fun main() => [1, 2] + 3")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("cannot unify"))
      assert/is-true(errors.length > 0)

    // --- negative indexing ---
    dtest("negative index emits length adjustment")
      val code = emit-typed-program("fun main() => [10, 20, 30][-1]")
      assert/is-true(code.contains(".length"))

    // --- in operator ---
    dtest("in operator type-checks")
      val ds = check-diagnostics("fun main() => 3 in [1, 2, 3]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("cannot"))
      assert/is-true(errors.length == 0)

    dtest("in operator emits any")
      val code = emit-typed-program("fun main() => 3 in [1, 2, 3]")
      assert/is-true(code.contains(".any("))

    dtest("in operator returns bool")
      val ds = check-diagnostics("fun main() { let result = 3 in [1, 2, 3]; println(result && true) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("in operator type mismatch reports error")
      val ds = check-diagnostics("fun main() => \"hi\" in [1, 2, 3]")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("cannot unify"))
      assert/is-true(errors.length > 0)

    // --- Char literals ---
    dtest("char literal type-checks")
      val ds = check-diagnostics("fun main() => 'a'")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("char literal emits single quote")
      val code = emit-typed-program("fun main() => 'x'")
      assert/is-true(code.contains("'x'"))

    dtest("char list type-checks")
      val ds = check-diagnostics("fun main() => ['a', 'b', 'c']")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("char equality type-checks")
      val ds = check-diagnostics("fun main() => 'a' == 'b'")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("char and string mismatch reports error")
      val ds = check-diagnostics("fun main() => 'a' == \"a\"")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    // --- Maybe: Some / None ---
    dtest("Some emits Just")
      val code = emit-typed-program("fun main() => Some(42)")
      assert/is-true(code.contains("Just(42)"))

    dtest("None emits Nothing")
      val code = emit-typed-program("fun main() => None")
      assert/is-true(code.contains("Nothing"))

    dtest("Some type-checks without error")
      val ds = check-diagnostics("fun main() => Some(42)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("None type-checks without error")
      val ds = check-diagnostics("fun main() => None")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("match Some pattern emits Just")
      val code = emit-typed-program("fun main() { let x = Some(5); match x { Some(n) => n, None => 0 } }")
      assert/is-true(code.contains("Just(n)"))
      assert/is-true(code.contains("Nothing"))

    dtest("match maybe type-checks")
      val ds = check-diagnostics("fun main() { let x = Some(5); match x { Some(n) => n, None => 0 } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("println auto-wraps maybe with show")
      val code = emit-typed-program("fun main() { println(Some(42)) }")
      assert/is-true(code.contains(".show"))

    // --- Result: Ok / Err ---
    dtest("Ok emits Right")
      val code = emit-typed-program("fun main() => Ok(42)")
      assert/is-true(code.contains("Right(42)"))

    dtest("Err emits Left")
      val code = emit-typed-program("fun main() => Err(\"oops\")")
      assert/is-true(code.contains("Left(\"oops\")"))

    dtest("Ok type-checks without error")
      val ds = check-diagnostics("fun main() => Ok(42)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("Err type-checks without error")
      val ds = check-diagnostics("fun main() => Err(\"oops\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("match Ok/Err patterns emit Right/Left")
      val code = emit-typed-program("fun main() { let x = Ok(5); match x { Ok(n) => n, Err(e) => 0 } }")
      assert/is-true(code.contains("Right(n)"))
      assert/is-true(code.contains("Left("))

    dtest("match result type-checks")
      val ds = check-diagnostics("fun main() { let x = Ok(5); match x { Ok(n) => n, Err(e) => 0 } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("println auto-wraps result with show")
      val code = emit-typed-program("fun main() { println(Ok(42)) }")
      assert/is-true(code.contains(".show"))

    // --- Returning closures ---
    dtest("function returning closure omits return annotation")
      val code = emit-typed-program("fun make_adder(n) => (x) => x + n\nfun main() { println(make_adder(5)(10)) }")
      // Return type must NOT have `: (int) -> int` — Koka can't parse it
      assert/is-true(!code.contains(": (int) -> int"))
      assert/is-true(code.contains("fn(x)"))

    dtest("closure captures outer variable")
      val code = emit-typed-program("fun make_adder(n) => (x) => x + n\nfun main() { let add5 = make_adder(5); println(add5(10)) }")
      assert/is-true(code.contains("fn(x)"))

    // --- User-defined higher-order functions ---
    dtest("higher-order function with unresolved param types omits annotation")
      val code = emit-typed-program("fun apply(f, x) => f(x)\nfun double(n) => n * 2\nfun main() { println(apply(double, 5)) }")
      // Param annotation must NOT be broken `() -> ` syntax
      assert/is-true(!code.contains("() -> ,"))
      assert/is-true(!code.contains(": () ->"))

    dtest("higher-order function with typed callback emits valid annotation")
      val code = emit-typed-program("fun twice(f, x) => f(f(x))\nfun double(n) => n * 2\nfun main() { println(twice(double, 3)) }")
      assert/is-true(!code.contains("() -> ,"))

    dtest("closure stored in let variable")
      val code = emit-typed-program("fun main() { let f = (x) => x * 2; println(f(5)) }")
      assert/is-true(code.contains("fn(x)"))

    // --- Type annotations ---
    dtest("let with type annotation type-checks")
      val ds = check-diagnostics("fun main() { let x: int = 42; println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("let type annotation mismatch reports error")
      val ds = check-diagnostics("fun main() { let x: int = \"hello\"; println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("function param type annotations emit correctly")
      val code = emit-typed-program("fun add(a: int, b: int) : int => a + b\nfun main() { println(add(1, 2)) }")
      assert/is-true(code.contains("a : int"))
      assert/is-true(code.contains("b : int"))

    dtest("function return type annotation emits correctly")
      val code = emit-typed-program("fun double(n: int) : int => n * 2\nfun main() { println(double(5)) }")
      assert/is-true(code.contains(": int"))

    dtest("tuple type annotation works")
      val code = emit-typed-program("fun swap(p: (int, int)) : (int, int) => (p.1, p.0)\nfun main() { println(swap((3, 7))) }")
      assert/is-true(code.contains("(int, int)"))

    dtest("list type annotation works")
      val ds = check-diagnostics("fun main() { let xs: list<int> = [1, 2, 3]; println(xs) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("maybe type annotation works")
      val ds = check-diagnostics("fun main() { let x: maybe<int> = Some(42); println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("partial annotations work — unannotated params inferred")
      val code = emit-typed-program("fun add(a: int, b) => a + b\nfun main() { println(add(1, 2)) }")
      assert/is-true(code.contains("a : int"))
      assert/is-true(code.contains("b : int"))

    // --- for-each collection loops ---
    dtest("for-each emits foreach")
      val code = emit-typed-program("fun main() { let xs = [1, 2, 3]; for x in xs { println(x) } }")
      assert/is-true(code.contains(".foreach"))

    dtest("for-each type-checks")
      val ds = check-diagnostics("fun main() { let xs = [1, 2, 3]; for x in xs { println(x) } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("for-each infers element type")
      val code = emit-typed-program("fun main() { let xs = [1, 2, 3]; for x in xs { println(x * 2) } }")
      assert/is-true(code.contains(".show"))

    dtest("for-each with string list")
      val code = emit-typed-program("fun main() { let ws = [\"hi\", \"there\"]; for w in ws { println(w) } }")
      assert/is-true(code.contains(".foreach"))

    dtest("range for loop still works")
      val code = emit-typed-program("fun main() { for i in 1..5 { println(i) } }")
      assert/is-true(code.contains("for(1, 5)"))

    // -----------------------------------------------------------------
    // String utility functions
    // -----------------------------------------------------------------

    dtest("str_length type-checks")
      val ds = check-diagnostics("fun main() => str_length(\"hello\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("str_length emits .count")
      val code = emit-typed-program("fun main() => str_length(\"hello\")")
      assert/is-true(code.contains(".count"))

    dtest("str_length returns int")
      val ds = check-diagnostics("fun main() { let n = str_length(\"hi\"); n + 1 }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("str_length on non-string reports error")
      val ds = check-diagnostics("fun main() => str_length(42)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("contains type-checks")
      val ds = check-diagnostics("fun main() => contains(\"hello world\", \"world\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("contains emits .contains")
      val code = emit-typed-program("fun main() => contains(\"hello\", \"ell\")")
      assert/is-true(code.contains(".contains("))

    dtest("contains returns bool")
      val ds = check-diagnostics("fun main() { if contains(\"abc\", \"b\") { 1 } else { 0 } }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("starts_with type-checks")
      val ds = check-diagnostics("fun main() => starts_with(\"hello\", \"hel\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("starts_with emits .starts-with .is-just")
      val code = emit-typed-program("fun main() => starts_with(\"hello\", \"he\")")
      assert/is-true(code.contains(".starts-with("))
      assert/is-true(code.contains(".is-just"))

    dtest("ends_with type-checks")
      val ds = check-diagnostics("fun main() => ends_with(\"hello\", \"llo\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("ends_with emits .ends-with .is-just")
      val code = emit-typed-program("fun main() => ends_with(\"hello\", \"lo\")")
      assert/is-true(code.contains(".ends-with("))
      assert/is-true(code.contains(".is-just"))

    dtest("trim type-checks")
      val ds = check-diagnostics("fun main() => trim(\"  hi  \")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("trim emits .trim")
      val code = emit-typed-program("fun main() => trim(\"  hi  \")")
      assert/is-true(code.contains(".trim"))

    dtest("trim returns string")
      val ds = check-diagnostics("fun main() => trim(\"  hi  \") + \"!\"")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("trim_start emits .trim-left")
      val code = emit-typed-program("fun main() => trim_start(\"  hi\")")
      assert/is-true(code.contains(".trim-left"))

    dtest("trim_end emits .trim-right")
      val code = emit-typed-program("fun main() => trim_end(\"hi  \")")
      assert/is-true(code.contains(".trim-right"))

    dtest("to_upper type-checks")
      val ds = check-diagnostics("fun main() => to_upper(\"hello\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("to_upper emits .to-upper")
      val code = emit-typed-program("fun main() => to_upper(\"hello\")")
      assert/is-true(code.contains(".to-upper"))

    dtest("to_lower emits .to-lower")
      val code = emit-typed-program("fun main() => to_lower(\"HELLO\")")
      assert/is-true(code.contains(".to-lower"))

    dtest("split type-checks")
      val ds = check-diagnostics("fun main() => split(\"a,b,c\", \",\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch") || d.message.contains("undefined"))
