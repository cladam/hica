    dtest("show emits show not hc_show")
      val code = emit-typed-program("fun main() => show(42)")
      assert/is-true(code.contains("show("))
      assert/is-true(!code.contains("hc_show"))

    // --- index_of ---

    dtest("index_of type-checks")
