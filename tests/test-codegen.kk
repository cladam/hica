    dtest("is_err emits is-left")
      val code = emit-typed-program("fun main() => is_err(Err(\"oops\"))")
      assert/is-true(code.contains(".is-left"))

    dtest("is_ok type-checks without error")
      val ds = check-diagnostics("fun main() => is_ok(Ok(42))")
      val errors = ds.filter(fn(d) d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("maybe combinators work with pipe syntax")
      val ds = check-diagnostics("fun main() { let x = Some(5) |> map_maybe((n) => n + 1); println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("undefined") || d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("result combinators work with pipe syntax")
      val ds = check-diagnostics("fun main() { let x = Ok(5) |> map_result((n) => n * 2); println(x) }")
      val errors = ds.filter(fn(d) d.message.contains("undefined") || d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("read_lines emits read_file call")
      val code = emit-typed-program("fun read_lines(p: string) => read_file(p)\nfun main() => read_lines(\"test.txt\")")
      assert/is-true(code.contains("read-text-file("))

    dtest("path variable is marshalled to avoid koka clash")
      val code = emit-typed-program("fun main() { let path = \"test.txt\"\nread_file(path) }")
      assert/is-true(code.contains("hc-path") || code.contains("hc_path"))

    // --- Range patterns ---
    dtest("emit range pattern as guard")
      val code = emit-typed-program("fun classify(n: int) => match n { 1..=5 => \"small\", _ => \"other\" }")
      assert/is-true(code.contains("hc__rng"))
      assert/is-true(code.contains(">= 1"))
      assert/is-true(code.contains("<= 5"))

    dtest("emit range pattern with existing guard")
      val code = emit-typed-program("fun try_it(n: int) => match n { 1..=10 if n > 5 => \"high\", _ => \"low\" }")
      assert/is-true(code.contains("hc__rng"))
      assert/is-true(code.contains(">= 1"))
      assert/is-true(code.contains("<= 10"))

    // --- pub visibility ---
    dtest("emit pub function")
      val code = emit-typed-program("pub fun add(a: int, b: int) : int => a + b\nfun main() => add(1, 2)")
      assert/is-true(code.contains("pub fun"))

    dtest("emit non-pub function has no pub prefix")
      val code = emit-typed-program("fun add(a: int, b: int) : int => a + b\nfun main() => add(1, 2)")
      assert/is-true(!code.contains("pub fun"))

    // --- input() ---
    dtest("input emits print and readline")
      val code = emit-typed-program("fun main() { let name = input(\"Name: \")\nprintln(name) }")
      assert/is-true(code.contains("print("))
      assert/is-true(code.contains("readline()"))

    dtest("input imports std/os/readline")
      val code = emit-typed-program("fun main() { let x = input(\"hi\")\nprintln(x) }")
      assert/is-true(code.contains("std/os/readline"))

    dtest("no readline import without input")
      val code = emit-typed-program("fun main() => println(42)")
      assert/is-true(!code.contains("readline"))

    dtest("input type-checks as string")
      val ds = check-diagnostics("fun main() { let x = input(\"name: \")\nprintln(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- Bitwise operations ---
    dtest("bit_and emits int32.and")
      val code = emit-typed-program("fun main() => println(bit_and(255, 15))")
      assert/is-true(code.contains(".int32.and("))
      assert/is-true(code.contains(".int32).int"))

    dtest("bit_or emits int32.or")
      val code = emit-typed-program("fun main() => println(bit_or(255, 256))")
      assert/is-true(code.contains(".int32.or("))

    dtest("bit_xor emits int32.xor")
      val code = emit-typed-program("fun main() => println(bit_xor(170, 255))")
      assert/is-true(code.contains(".int32.xor("))

    dtest("bit_not emits int32.not")
      val code = emit-typed-program("fun main() => println(bit_not(0))")
      assert/is-true(code.contains(".int32.not.int"))

    dtest("bit_shl emits int32.shl")
      val code = emit-typed-program("fun main() => println(bit_shl(1, 8))")
      assert/is-true(code.contains(".int32.shl("))

    dtest("bit_shr emits int32.shr")
      val code = emit-typed-program("fun main() => println(bit_shr(256, 4))")
      assert/is-true(code.contains(".int32.shr("))

    dtest("bitwise imports std/num/int32")
      val code = emit-typed-program("fun main() => println(bit_and(1, 2))")
      assert/is-true(code.contains("std/num/int32"))

    dtest("no int32 import without bitwise")
      val code = emit-typed-program("fun main() => println(42)")
      assert/is-true(!code.contains("std/num/int32"))

    dtest("bitwise type-checks as int -> int")
      val ds = check-diagnostics("fun main() { let x = bit_and(255, 15)\nprintln(x + 1) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("bit_not type-checks as (int) -> int")
      val ds = check-diagnostics("fun main() { let x = bit_not(0)\nprintln(x + 1) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- Binary & hex literals ---
    dtest("binary literal emits correct int")
      val code = emit-typed-program("fun main() => println(0b1010)")
      assert/is-true(code.contains("10"))

    dtest("hex literal emits correct int")
      val code = emit-typed-program("fun main() => println(0xFF)")
      assert/is-true(code.contains("255"))

    dtest("underscore separators in decimal")
      val code = emit-typed-program("fun main() => println(1_000_000)")
      assert/is-true(code.contains("1000000"))

    dtest("binary literal in arithmetic")
      val ds = check-diagnostics("fun main() { let x = 0b1010 + 5\nprintln(x) }")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("hex literal with bitwise op")
      val code = emit-typed-program("fun main() => println(bit_and(0xFF, 0x0F))")
      assert/is-true(code.contains(".int32.and("))

    // --- Bit-level matching ---
    dtest("bit pattern emits mask-and-compare guard")
      val code = emit-typed-program("fun main() {\n  let x = 200\n  match x {\n    0b1100_???? => println(1),\n    _ => println(0)\n  }\n}")
      assert/is-true(code.contains("hc__bits.int32.and("))
      assert/is-true(code.contains(".int32).int == "))

    dtest("bit pattern imports std/num/int32")
      val code = emit-typed-program("fun main() {\n  match 5 {\n    0b1?0? => println(1),\n    _ => println(0)\n  }\n}")
      assert/is-true(code.contains("std/num/int32"))

    dtest("bit pattern type-checks scrutinee as int")
      val ds = check-diagnostics("fun main() {\n  let x = 200\n  match x {\n    0b1100_???? => println(1),\n    _ => println(0)\n  }\n}")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("bit pattern combined with guard")
      val code = emit-typed-program("fun main() {\n  let x = 200\n  match x {\n    0b1100_???? if x > 100 => println(1),\n    _ => println(0)\n  }\n}")
      assert/is-true(code.contains("hc__bits.int32.and("))
      assert/is-true(code.contains("&& (x > 100)"))

    // --- Map literals ---
    dtest("empty map emits empty list")
      val code = emit-typed-program("fun main() {\n  let m = {:}\n  let m2 = m.map_set(\"a\", 1)\n  println(m2)\n}")
      assert/is-true(code.contains("[]"))

    dtest("map literal emits list of tuples")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  println(m)\n}")
      assert/is-true(code.contains("(\"a\", 1)"))
      assert/is-true(code.contains("(\"b\", 2)"))

    dtest("map_get emits find")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1}\n  println(m.map_get(\"a\"))\n}")
      assert/is-true(code.contains(".find("))

    dtest("map_set emits update-or-append")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1}\n  let m2 = m.map_set(\"b\", 2)\n  println(m2)\n}")
      assert/is-true(code.contains(".any("))
      assert/is-true(code.contains(".map("))

    dtest("map_remove emits filter")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  let m2 = m.map_remove(\"a\")\n  println(m2)\n}")
      assert/is-true(code.contains(".filter("))

    dtest("map_keys emits map projection")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  println(m.map_keys())\n}")
      assert/is-true(code.contains(".map(fn((hc__k, _)) hc__k)"))

    dtest("map_values emits map projection")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  println(m.map_values())\n}")
      assert/is-true(code.contains(".map(fn((_, hc__v)) hc__v)"))

    dtest("map_contains_key emits any")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1}\n  println(m.map_contains_key(\"a\"))\n}")
      assert/is-true(code.contains(".any("))

    dtest("map_size emits length")
      val code = emit-typed-program("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  println(m.map_size())\n}")
      assert/is-true(code.contains(".length"))

    dtest("map type-checks keys as same type")
      val ds = check-diagnostics("fun main() {\n  let m = {\"a\": 1, \"b\": 2}\n  println(m)\n}")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    // --- Mutual recursion ---
    dtest("mutual recursion type-checks without error")
      val ds = check-diagnostics("fun check_even(n) => if n == 0 { true } else { check_odd(n - 1) }\nfun check_odd(n) => if n == 0 { false } else { check_even(n - 1) }\nfun main() => check_even(4)")
      val errors = ds.filter(fn(d) d.message.contains("undefined") || d.message.contains("cannot be found"))
      assert/is-true(errors.length == 0)

    dtest("mutual recursion omits return annotation for div")
      val code = emit-typed-program("fun check_even(n) => if n == 0 { true } else { check_odd(n - 1) }\nfun check_odd(n) => if n == 0 { false } else { check_even(n - 1) }\nfun main() => check_even(4)")
      // Both mutually recursive functions should omit return annotation
      assert/is-true(code.contains("fun hc_check_even(n : int)\n"))
      assert/is-true(code.contains("fun hc_check_odd(n : int)\n"))

    dtest("mutual recursion marks both functions as recursive")
      val code = emit-typed-program("fun check_even(n) => if n == 0 { true } else { check_odd(n - 1) }\nfun check_odd(n) => if n == 0 { false } else { check_even(n - 1) }\nfun main() => check_even(4)")
      // Neither should have `: bool` return annotation
      assert/is-true(!code.contains("fun hc_check_even(n : int) : bool"))
      assert/is-true(!code.contains("fun hc_check_odd(n : int) : bool"))

    dtest("non-mutual functions still get return annotations")
      val code = emit-typed-program("fun add(a, b) => a + b\nfun double(x) => x * 2\nfun main() => add(double(3), 1)")
      assert/is-true(code.contains(": int"))

    dtest("self-recursion still works with mutual recursion support")
      val code = emit-typed-program("fun factorial(n) => if n <= 1 { 1 } else { n * factorial(n - 1) }\nfun main() => factorial(5)")
      assert/is-true(code.contains("fun hc_factorial("))
      assert/is-true(!code.contains("fun hc_factorial(n : int) : int"))

    dtest("three-way mutual recursion")
      val src = "fun fa(n) => if n <= 0 { 0 } else { fb(n - 1) }\nfun fb(n) => if n <= 0 { 1 } else { fc(n - 1) }\nfun fc(n) => if n <= 0 { 2 } else { fa(n - 1) }\nfun main() => fa(5)"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("fun hc_fa(n : int)\n"))
      assert/is-true(code.contains("fun hc_fb(n : int)\n"))
      assert/is-true(code.contains("fun hc_fc(n : int)\n"))

    // --- Import emission ---
    dtest("emit program with import")
      val src = "import \"greet\"\nfun main() => println(1)"
      val code = emit-program-show(src)
      assert/is-true(code.contains("import greet"))

    dtest("emit program with pub import")
      val src = "pub import \"utils\"\nfun main() => println(1)"
      val code = emit-program-show(src)
      assert/is-true(code.contains("pub import utils"))

    dtest("import module name is safe")
      val src = "import \"match\"\nfun main() => println(1)"
      val code = emit-program-show(src)
      assert/is-true(code.contains("import hc-match"))

    dtest("emit struct destructuring pattern")
      val src = "struct Point { x: int, y: int }\nfun main() {\n  let p = Point { x: 3, y: 4 }\n  match p {\n    Point { x, y } => println(x)\n  }\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Point(x, y)"))

    dtest("emit struct pattern with literal")
      val src = "struct Point { x: int, y: int }\nfun main() {\n  let p = Point { x: 0, y: 5 }\n  match p {\n    Point { x: 0, y } => println(y)\n  }\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Point(0, y)"))

    dtest("emit struct pattern with wildcard field")
      val src = "struct Point { x: int, y: int }\nfun main() {\n  let p = Point { x: 3, y: 4 }\n  match p {\n    Point { x } => println(x)\n  }\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Point(x, _)"))

    dtest("struct pattern unknown field error")
      val ds = check-diagnostics("struct Point { x: int, y: int }\nfun main() {\n  let p = Point { x: 3, y: 4 }\n  match p {\n    Point { z } => println(1)\n  }\n}")
      assert/is-true(ds.any(fn(d) d.message.contains("no field 'z'")))

    dtest("emit empty list pattern")
      val src = "fun f(xs: list<int>) : int => match xs {\n  [] => 0,\n  _ => 1\n}\nfun main() => println(f([]))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Nil"))

    dtest("emit single element list pattern")
      val src = "fun f(xs: list<int>) : int => match xs {\n  [x] => x,\n  _ => 0\n}\nfun main() => println(f([42]))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Cons(x, Nil)"))

    dtest("emit list pattern with rest")
      val src = "fun f(xs: list<int>) : int => match xs {\n  [x, ..rest] => x,\n  _ => 0\n}\nfun main() => println(f([1, 2, 3]))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Cons(x, rest)"))

    dtest("emit two element list pattern")
      val src = "fun f(xs: list<int>) : int => match xs {\n  [a, b] => a,\n  _ => 0\n}\nfun main() => println(f([1, 2]))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Cons(a, Cons(b, Nil))"))

    // --- ? operator ---

    dtest("emit try on maybe unwraps with match")
      val src = "fun f(s: string) : maybe<int> {\n  let x = parse_int(s)?\n  Some(x)\n}\nfun main() => println(f(\"42\"))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("Just(hc__v) -> hc__v"))
      assert/is-true(code.contains("Nothing -> hica-early-none()"))

    dtest("emit try handler wraps function body")
      val src = "fun f(s: string) : maybe<int> {\n  let x = parse_int(s)?\n  Some(x)\n}\nfun main() => println(f(\"42\"))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("with handler"))
      assert/is-true(code.contains("ctl hica-early-none() -> Nothing"))

    dtest("emit try effect declaration")
      val src = "fun f(s: string) : maybe<int> {\n  let x = parse_int(s)?\n  Some(x)\n}\nfun main() => println(f(\"42\"))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("effect hica-early-maybe"))

    dtest("emit try on maybe keeps return annotation")
      val src = "fun f(s: string) : maybe<int> {\n  let x = parse_int(s)?\n  Some(x)\n}\nfun main() => println(f(\"42\"))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("hc_f(s : string) : maybe<int>"))

    dtest("emit try multiple maybe unwraps")
      val src = "fun f(a: string, b: string) : maybe<int> {\n  let x = parse_int(a)?\n  let y = parse_int(b)?\n  Some(x + y)\n}\nfun main() => println(f(\"3\", \"4\"))"
      val code = emit-typed-program(src)
      // Both ? calls should emit match/unwrap
      val count = code.lines.filter(fn(l) l.contains("hica-early-none()")).length
      assert/is-true(count >= 2)

    dtest("emit try type error on non-maybe non-result")
      val src = "fun f(x: int) : int {\n  let y = x?\n  y\n}\nfun main() => println(f(42))"
      val ds = check-diagnostics(src)
      val errs = ds.filter(fn(d) d.message.contains("? operator requires"))
      assert/is-true(errs.length > 0)

    // --- Tuple destructuring in lambda ---
    dtest("emit tuple destructuring lambda")
      val src = "fun main() {\n  let pairs = [(1, \"a\"), (2, \"b\")]\n  let keys = pairs.map(((k, v)) => k)\n  println(keys)\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("fn((k, v)) k"))

    dtest("emit tuple destructuring lambda with body expression")
      val src = "fun main() {\n  let pairs = [(1, 2), (3, 4)]\n  let sums = pairs.map(((a, b)) => a + b)\n  println(sums)\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("fn((a, b))"))

    dtest("emit tuple destructuring lambda in filter")
      val src = "fun main() {\n  let pairs = [(1, \"x\"), (2, \"y\")]\n  let big = pairs.filter(((n, s)) => n > 1)\n  println(big)\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("fn((n, s))"))

    dtest("emit normal lambda still works")
      val src = "fun main() {\n  let xs = [1, 2, 3]\n  let doubled = xs.map((x) => x * 2)\n  println(doubled)\n}"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("fn(x)"))

    dtest("emit float show in enum variant")
      val src = "type Temp {\n  Celsius(v: float)\n}\nfun main() => println(Celsius(36.6))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains("float64/show(v)"))

    dtest("emit div effect on show for recursive enum")
      val src = "type Yaml {\n  YStr(value: string),\n  YList(items: list<Yaml>)\n}\nfun main() => println(YStr(\"hi\"))"
      val code = emit-typed-program(src)
      assert/is-true(code.contains(": div string"))

    dtest("emit lambda with let destructuring as indented block")
      val src = "fun main() {\n  let xs = [(1, 2), (3, 4)]\n  xs |> find((e) => { let (k, _v) = e; k == 3 })\n}"
      val code = emit-typed-program(src)
      // The lambda body should be on a new indented line, not inline
      assert/is-true(code.contains("fn(e)\n"))
      assert/is-true(code.contains("val (k,"))

    dtest("emit trailing lambda for multiline lambda in call")
      val src = "fun main() {\n  let xs = [(1, 2), (3, 4)]\n  xs |> find((e) => { let (k, _v) = e; k == 3 })\n}"
      val code = emit-typed-program(src)
      // Should use trailing lambda syntax: find(xs) fn(e) ... not find(xs, fn(e) ...)
      assert/is-true(code.contains("find(xs)"))
      assert/is-true(!code.contains("find(xs, fn"))

    dtest("emit map_maybe with multiline lambda hoists to val")
      val src = "fun main() {\n  let xs = [(1, 2), (3, 4)]\n  xs |> find((e) => { let (k, _v) = e; k == 3 }) |> map_maybe((e) => { let (_k, v) = e; v })\n}"
      val code = emit-typed-program(src)
      // Should hoist the find call to val hc__mm and match on it
      assert/is-true(code.contains("val hc__mm"))
      assert/is-true(code.contains("match hc__mm"))

    // --- chr / ord / char_to_string ---
    dtest("chr type-checks int to char")
      val ds = check-diagnostics("fun main() => chr(65)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("chr emits .char")
      val code = emit-typed-program("fun main() => chr(65)")
      assert/is-true(code.contains("65.char"))

    dtest("ord type-checks char to int")
      val ds = check-diagnostics("fun main() => ord('A')")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("ord emits .int")
      val code = emit-typed-program("fun main() => ord('A')")
      assert/is-true(code.contains("'A'.int"))

    dtest("char_to_string type-checks char to string")
      val ds = check-diagnostics("fun main() => char_to_string('A')")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length == 0)

    dtest("char_to_string emits .string")
      val code = emit-typed-program("fun main() => char_to_string('A')")
      assert/is-true(code.contains("'A'.string"))

    dtest("chr rejects string argument")
      val ds = check-diagnostics("fun main() => chr(\"A\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("ord rejects int argument")
      val ds = check-diagnostics("fun main() => ord(42)")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    // --- System clock primitives ---
    dtest("now_unix emits @default-utc with unix-timestamp")
      val code = emit-typed-program("fun main() => now_unix()")
      assert/is-true(code.contains("@default-utc"))
      assert/is-true(code.contains("now()"))
      assert/is-true(code.contains("unix-timestamp"))
      assert/is-true(code.contains("truncate"))

    dtest("now_iso emits @default-utc with show-iso")
      val code = emit-typed-program("fun main() => now_iso()")
      assert/is-true(code.contains("@default-utc"))
      assert/is-true(code.contains("now()"))
      assert/is-true(code.contains("show-iso"))
      assert/is-true(code.contains("trim-right"))

    dtest("unix_to_iso emits @default-utc with unix-instant")
      val code = emit-typed-program("fun main() => unix_to_iso(0)")
      assert/is-true(code.contains("@default-utc"))
      assert/is-true(code.contains("unix-instant("))
      assert/is-true(code.contains("show-iso"))
      assert/is-true(code.contains("trim-right"))

    dtest("now_unix imports std/time modules")
      val code = emit-typed-program("fun main() => now_unix()")
      assert/is-true(code.contains("import std/time/chrono"))
      assert/is-true(code.contains("import std/time/utc"))
      assert/is-true(code.contains("import std/time/time"))
      assert/is-true(code.contains("import std/time/format"))
      assert/is-true(code.contains("import std/num/ddouble"))

    dtest("now_iso imports std/time modules")
      val code = emit-typed-program("fun main() => now_iso()")
      assert/is-true(code.contains("import std/time/chrono"))
      assert/is-true(code.contains("import std/time/utc"))

    dtest("unix_to_iso imports std/time modules")
      val code = emit-typed-program("fun main() => unix_to_iso(1000)")
      assert/is-true(code.contains("import std/time/chrono"))
      assert/is-true(code.contains("import std/num/ddouble"))

    dtest("no time import when not using time primitives")
      val code = emit-typed-program("fun main() => println(42)")
      assert/is-true(!code.contains("std/time"))
      assert/is-true(!code.contains("std/num/ddouble"))

    dtest("now_unix type-checks without error")
      val ds = check-diagnostics("fun main() => now_unix()")
      val errors = ds.filter(fn(d) d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("now_iso type-checks without error")
      val ds = check-diagnostics("fun main() => now_iso()")
      val errors = ds.filter(fn(d) d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("unix_to_iso type-checks without error")
      val ds = check-diagnostics("fun main() => unix_to_iso(1716800000)")
      val errors = ds.filter(fn(d) d.message.contains("undefined"))
      assert/is-true(errors.length == 0)

    dtest("unix_to_iso rejects string argument")
      val ds = check-diagnostics("fun main() => unix_to_iso(\"not-an-int\")")
      val errors = ds.filter(fn(d) d.message.contains("type mismatch"))
      assert/is-true(errors.length > 0)

    dtest("now_unix suppresses return type annotation as effectful prim")
      val code = emit-typed-program("fun get_time() : int => now_unix()\nfun main() => get_time()")
      assert/is-true(!code.contains("hc_get_time() : int"))
