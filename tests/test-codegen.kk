    dtest("replace emits .replace-all")
      val code = emit-typed-program("fun main() => replace(\"hello\", \"l\", \"r\")")
      assert/is-true(code.contains(".replace-all("))

    dtest("join type-checks")
      val ds = check-diagnostics("fun main() => join([\"a\", \"b\"], \",\")")
